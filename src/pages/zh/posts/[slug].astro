---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts-zh');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

const rawContent = post.body;
const tocItems: { level: number; text: string; id: string }[] = [];

const mdHeadingRegex = /^(#{2,3})\s+(.+)$/gm;
let match;
while ((match = mdHeadingRegex.exec(rawContent)) !== null) {
  if (match[1].length !== 2) continue;
  const text = match[2].trim();
  const id = text.toLowerCase().replace(/['''\u2018\u2019]/g, '').replace(/[^\w\u4e00-\u9fff]+/g, '-').replace(/^-|-$/g, '');
  tocItems.push({ level: 2, text, id });
}

const htmlH2Regex = /<h2[^>]*>(.*?)<\/h2>/gi;
while ((match = htmlH2Regex.exec(rawContent)) !== null) {
  const text = match[1].replace(/<[^>]+>/g, '').trim();
  const id = text.toLowerCase().replace(/['''\u2018\u2019]/g, '').replace(/[^\w\u4e00-\u9fff]+/g, '-').replace(/^-|-$/g, '');
  if (!tocItems.find(t => t.id === id)) tocItems.push({ level: 2, text, id });
}

tocItems.sort((a, b) => rawContent.indexOf(a.text) - rawContent.indexOf(b.text));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.summary,
  "datePublished": post.data.date.toISOString().split('T')[0],
  "dateModified": post.data.date.toISOString().split('T')[0],
  "url": Astro.url.href,
  "publisher": { "@type": "Organization", "name": "AI Verse", "url": import.meta.env.SITE + import.meta.env.BASE_URL },
  "keywords": post.data.tags?.join(', '),
};
---

<BaseLayout title={post.data.title} description={post.data.summary} lang="zh">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="article-outer">
    <div class="article-main">
      <a href={`${base}/zh/articles/`} class="back-link">← 返回列表</a>
      <article>
        <header class="article-header">
          <div class="tag-list">
            {post.data.tags.map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
          <h1>{post.data.title}</h1>
          <div class="article-meta">
            <span>{formatDate(post.data.date)}</span>
            <span class="badge badge-difficulty">{post.data.difficulty}</span>
            <span class="view-count">👁 <span id="waline-pv">--</span> 次阅读</span>
          </div>
        </header>
        {post.data.cover && (
          <img src={post.data.cover} alt={post.data.title} class="cover-image" />
        )}
        <div class="prose"><Content /></div>
      </article>

      <!-- 点赞 / 踩 -->
      <div class="article-reactions">
        <button class="reaction-btn" id="btn-like">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
          <span class="reaction-count" id="count-like">--</span>
        </button>
        <button class="reaction-btn reaction-btn--down" id="btn-dislike">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/><path d="M17 2h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
          <span class="reaction-count" id="count-dislike">--</span>
        </button>
      </div>

      <!-- 评论区 -->
      <div id="waline-comment" class="waline-wrap"></div>
    </div>

    {tocItems.length > 0 && (
      <aside class="toc-sidebar">
        <div class="toc-box">
          <div class="toc-title">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>
            目录
          </div>
          <nav>
            <ul class="toc-list">
              {tocItems.map((item) => (
                <li class={`toc-item toc-h${item.level}`}>
                  <a href={`#${item.id}`} class="toc-link">{item.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>
    )}
  </div>

  <script>
    const toc = document.querySelector<HTMLElement>('.toc-sidebar');
    const articleMain = document.querySelector<HTMLElement>('.article-main');
    const prose = document.querySelector<HTMLElement>('.prose');

    const domHeadings = Array.from(document.querySelectorAll<HTMLElement>('.prose h2'));
    const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-link'));
    tocLinks.forEach(a => {
      const id = a.getAttribute('href')?.slice(1);
      if (!id) return;
      if (!document.getElementById(id)) {
        const text = a.textContent?.trim();
        const h = domHeadings.find(h => h.textContent?.trim() === text);
        if (h) h.id = id;
      }
    });

    tocLinks.forEach(a => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const id = a.getAttribute('href')?.slice(1);
        if (!id) return;
        const target = document.getElementById(id);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    function positionToc() {
      if (!toc || !articleMain || !prose) return;
      const rect = articleMain.getBoundingClientRect();
      const viewportWidth = window.innerWidth;
      if (viewportWidth - rect.right > 280) {
        toc.style.left = (rect.right + 32) + 'px';
        const proseTop = prose.getBoundingClientRect().top;
        const top = Math.max(80, proseTop);
        toc.style.top = top + 'px';
        toc.style.display = 'block';
      } else {
        toc.style.display = 'none';
      }
    }

    positionToc();
    window.addEventListener('resize', positionToc);
    window.addEventListener('scroll', positionToc, { passive: true });

    function onScroll() {
      let current = '';
      for (const h of domHeadings) {
        if (h.getBoundingClientRect().top <= 100) current = h.id;
      }
      tocLinks.forEach(a => {
        const href = a.getAttribute('href') || '';
        a.classList.toggle('toc-active', href === '#' + current);
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    // 点赞 / 踩
    const WALINE = 'https://waline-bay-nu.vercel.app';
    const articlePath = window.location.pathname;
    const storageKey = 'reaction:' + articlePath;

    async function fetchReactions() {
      try {
        const res = await fetch(`${WALINE}/api/article?path=${encodeURIComponent(articlePath)}`);
        const json = await res.json();
        const d = json.data?.[0];
        document.getElementById('count-like').textContent = d?.reaction0 ?? 0;
        document.getElementById('count-dislike').textContent = d?.reaction1 ?? 0;
      } catch {}
    }

    async function sendReaction(type) {
      const voted = localStorage.getItem(storageKey);
      if (voted === type) return;
      try {
        await fetch(`${WALINE}/api/article`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url: articlePath, type }),
        });
        localStorage.setItem(storageKey, type);
        document.getElementById('btn-like').classList.toggle('reaction-btn--active', type === 'reaction0');
        document.getElementById('btn-dislike').classList.toggle('reaction-btn--active', type === 'reaction1');
        fetchReactions();
      } catch {}
    }

    const voted = localStorage.getItem(storageKey);
    if (voted === 'reaction0') document.getElementById('btn-like').classList.add('reaction-btn--active');
    if (voted === 'reaction1') document.getElementById('btn-dislike').classList.add('reaction-btn--active');

    document.getElementById('btn-like').addEventListener('click', () => sendReaction('reaction0'));
    document.getElementById('btn-dislike').addEventListener('click', () => sendReaction('reaction1'));
    fetchReactions();
  </script>

  <link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />
  <style>
    .article-reactions {
      display: flex;
      gap: 12px;
      justify-content: center;
      margin: 40px 0 8px;
    }
    .reaction-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      padding: 14px 32px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.1);
      cursor: pointer;
      color: var(--text-dim);
      transition: all 0.2s;
      min-width: 80px;
    }
    .reaction-btn:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(79,172,254,0.2); }
    .reaction-btn--down:hover { border-color: var(--danger); color: var(--danger); box-shadow: 0 8px 24px rgba(248,81,73,0.2); }
    .reaction-btn--active { border-color: var(--accent) !important; color: var(--accent) !important; background: rgba(79,172,254,0.08); }
    .reaction-btn--down.reaction-btn--active { border-color: var(--danger) !important; color: var(--danger) !important; background: rgba(248,81,73,0.08); }
    .reaction-count { font-size: 18px; font-weight: 700; font-family: var(--font-mono); line-height: 1; }
  </style>
  <script type="module">
    import { init, pageviewCount } from 'https://unpkg.com/@waline/client@v3/dist/waline.js';
    init({
      el: '#waline-comment',
      serverURL: 'https://waline-bay-nu.vercel.app',
      lang: 'zh-CN',
      pageview: '#waline-pv',
      comment: true,
      dark: 'html[data-theme="dark"]',
    });
  </script>
</BaseLayout>
