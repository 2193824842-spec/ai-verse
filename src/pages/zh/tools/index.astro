---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { TOOLS } from '../../../data/tools';

const toolEntries = await getCollection('tools-zh');
const detailSlugs = new Set(toolEntries.map(e => e.slug));

// Build inline compare data map
const compareDataMap: Record<string, {
  name: string; url: string; tag: string; category: string;
  longDesc: string; pros: string[]; cons: string[];
}> = {};
for (const e of toolEntries) {
  compareDataMap[e.slug] = {
    name: e.data.name, url: e.data.url, tag: e.data.tag,
    category: e.data.category, longDesc: e.data.longDesc,
    pros: e.data.pros ?? [], cons: e.data.cons ?? [],
  };
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const TAG_COLORS: Record<string, string> = {
  '免费': 'tag-free',
  '付费': 'tag-paid',
  '免费/付费': 'tag-freemium',
};

const CATEGORY_COLORS: Record<string, string> = {
  coding:       '#4FACFE',
  models:       '#A855F7',
  writing:      '#10B981',
  image:        '#F59E0B',
  video:        '#EF4444',
  productivity: '#06B6D4',
  audio:        '#EC4899',
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "AI工具导航 2026",
  "description": "2026年最全AI工具导航，收录AI编程、大模型、写作、图像生成、视频生成等各类AI工具，持续更新。",
  "url": Astro.url.href,
};

const CATEGORY_ICONS: Record<string, string> = {
  coding:       `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  models:       `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>`,
  writing:      `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
  image:        `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
  video:        `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
  productivity: `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  audio:        `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
};
---

<BaseLayout title="AI工具导航 2026 · 精选AI工具大全" description="2026年最全AI工具导航，收录AI编程、大模型、写作、图像生成、视频生成等各类AI工具，持续更新。" lang="zh">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="page-header">
    <h1>AI 工具导航 2026</h1>
    <p class="page-desc">精选各类 AI 工具，持续更新 · <a href={`${base}/zh/articles/`}>查看评测文章 →</a></p>
  </div>

  <!-- 浮动侧边栏（滚动后出现） -->
  <div id="sticky-sidebar" class="sticky-sidebar">
    <div class="sticky-search-wrap">
      <svg viewBox="0 0 20 20" fill="none" width="13" height="13">
        <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.8"/>
        <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <input id="sticky-search-input" type="text" class="sticky-search-input" placeholder="搜索..." autocomplete="off" />
    </div>
    <nav class="sticky-cat-nav">
      <button class="sticky-cat-btn active" data-cat="all">全部</button>
      {TOOLS.map(cat => (
        <button class="sticky-cat-btn" data-cat={cat.slug}>{cat.category}</button>
      ))}
    </nav>
  </div>

  <div class="tools-top-bar">
    <div class="tools-search-wrap">
      <svg class="tools-search-icon" viewBox="0 0 20 20" fill="none">
        <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.8"/>
        <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <input id="tools-search-input" type="text" class="tools-search-input" placeholder="搜索工具..." autocomplete="off" />
      <span id="tools-search-count" class="tools-search-count" style="display:none"></span>
    </div>
    <div class="tools-cat-filter" id="tools-cat-nav">
      <button class="cat-btn active" data-cat="all">全部</button>
      {TOOLS.map(cat => (
        <button class="cat-btn" data-cat={cat.slug}>{cat.category}</button>
      ))}
    </div>
    <div class="tools-price-filter" id="tools-price-nav">
      <button class="price-btn active" data-price="all">全部</button>
      <button class="price-btn" data-price="免费">免费</button>
      <button class="price-btn" data-price="付费">付费</button>
      <button class="price-btn" data-price="免费/付费">增值付费</button>
    </div>
  </div>

  <!-- ── 精选区块 ── -->
  <div class="featured-section">
    <div class="featured-header">
      <button class="sort-btn active" data-sort="popular">🔥 热门</button>
      <button class="sort-btn" data-sort="latest">🆕 最新</button>
    </div>
    <ul class="featured-grid" id="featured-grid">
      {(() => {
        const popularSlugs = ['chatgpt','cursor','midjourney','claude','deepseek','sora','github-copilot','notion-ai'];
        const latestSlugs  = ['bolt-new','v0','lovable','devin','grok','suno','kling','hailuo'];
        const allTools = TOOLS.flatMap(c => c.items);
        return popularSlugs.map(slug => {
          const tool = allTools.find(t => t.slug === slug);
          if (!tool) return null;
          const hasDetail = detailSlugs.has(tool.slug);
          const href = hasDetail ? `${base}/zh/tools/${tool.slug}/` : tool.url;
          const isExternal = !hasDetail;
          const badgeClass = tool.tag === '免费' ? 'badge-free' : tool.tag === '付费' ? 'badge-paid' : 'badge-freemium';
          const badgeText  = tool.tag === '免费' ? 'Free' : tool.tag === '付费' ? 'Pro' : 'Freemium';
          return (
            <li class="tool-card featured-card" data-slug={tool.slug} data-name={tool.name} data-tag={tool.tag} data-sort="popular">
              <div class={`tool-badge ${badgeClass}`}>{badgeText}</div>
              <a href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined} class="tool-card-link">
                <img src={`https://www.google.com/s2/favicons?domain=${new URL(tool.url).hostname}&sz=64`} alt={tool.name} width="36" height="36" class="tool-favicon" loading="lazy" />
                <span class="tool-name">{tool.name}</span>
                <p class="tool-desc">{tool.desc}</p>
              </a>
              <button class="compare-btn" data-slug={tool.slug} data-name={tool.name}>+ 对比</button>
            </li>
          );
        });
      })()}
      {(() => {
        const latestSlugs = ['bolt-new','v0','lovable','devin','grok','suno','kling','hailuo'];
        const allTools = TOOLS.flatMap(c => c.items);
        return latestSlugs.map(slug => {
          const tool = allTools.find(t => t.slug === slug);
          if (!tool) return null;
          const hasDetail = detailSlugs.has(tool.slug);
          const href = hasDetail ? `${base}/zh/tools/${tool.slug}/` : tool.url;
          const isExternal = !hasDetail;
          const badgeClass = tool.tag === '免费' ? 'badge-free' : tool.tag === '付费' ? 'badge-paid' : 'badge-freemium';
          const badgeText  = tool.tag === '免费' ? 'Free' : tool.tag === '付费' ? 'Pro' : 'Freemium';
          return (
            <li class="tool-card featured-card" data-slug={tool.slug} data-name={tool.name} data-tag={tool.tag} data-sort="latest" style="display:none">
              <div class={`tool-badge ${badgeClass}`}>{badgeText}</div>
              <a href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined} class="tool-card-link">
                <img src={`https://www.google.com/s2/favicons?domain=${new URL(tool.url).hostname}&sz=64`} alt={tool.name} width="36" height="36" class="tool-favicon" loading="lazy" />
                <span class="tool-name">{tool.name}</span>
                <p class="tool-desc">{tool.desc}</p>
              </a>
              <button class="compare-btn" data-slug={tool.slug} data-name={tool.name}>+ 对比</button>
            </li>
          );
        });
      })()}
    </ul>
  </div>

  <!-- ── 主内容区 ── -->
  <div class="tools-main">
      {TOOLS.map(cat => {
        const catColor = CATEGORY_COLORS[cat.slug] ?? '#4FACFE';
        // 将 hex 转为 rgb 分量，用于半透明背景
        const r = parseInt(catColor.slice(1,3), 16);
        const g = parseInt(catColor.slice(3,5), 16);
        const b = parseInt(catColor.slice(5,7), 16);
        return (
          <section
            class="tool-section"
            id={cat.slug}
            style={`--section-color: ${catColor}; --section-color-rgb: ${r},${g},${b};`}
          >
            <h2 class="section-title" data-collapse-toggle>
              <span class="section-title-bar"></span>
              {cat.category}
              <svg class="section-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </h2>
            <ul class="tool-grid">
              {cat.items.map(tool => {
                const hasDetail = detailSlugs.has(tool.slug);
                const href = hasDetail ? `${base}/zh/tools/${tool.slug}/` : tool.url;
                const isExternal = !hasDetail;
                const badgeClass = tool.tag === '免费' ? 'badge-free' : tool.tag === '付费' ? 'badge-paid' : 'badge-freemium';
                const badgeText = tool.tag === '免费' ? 'Free' : tool.tag === '付费' ? 'Pro' : 'Freemium';
                return (
                  <li class="tool-card" data-slug={tool.slug} data-name={tool.name} data-tag={tool.tag}>
                    <div class={`tool-badge ${badgeClass}`}>{badgeText}</div>
                    <a
                      href={href}
                      target={isExternal ? '_blank' : undefined}
                      rel={isExternal ? 'noopener noreferrer' : undefined}
                      class="tool-card-link"
                    >
                      <img
                        src={`https://www.google.com/s2/favicons?domain=${new URL(tool.url).hostname}&sz=64`}
                        alt={tool.name}
                        width="36" height="36"
                        class="tool-favicon"
                        loading="lazy"
                      />
                      <span class="tool-name">{tool.name}</span>
                      <p class="tool-desc">{tool.desc}</p>
                    </a>
                    <button class="compare-btn" data-slug={tool.slug} data-name={tool.name}>+ 对比</button>
                  </li>
                );
              })}
            </ul>
          </section>
        );
      })}
    </div>
  </div>
  <script type="application/json" id="compare-data" set:html={JSON.stringify(compareDataMap)} />
</BaseLayout>

<!-- Compare bar -->
<div id="compare-bar" style="display:none">
  <div class="compare-bar-items" id="compare-bar-items"></div>
  <button id="compare-start-btn">开始对比</button>
  <button id="compare-close-bar">✕</button>
</div>

<!-- Compare panel -->
<div id="compare-panel" style="display:none">
  <div class="compare-panel-inner">
    <button id="compare-panel-close">✕</button>
    <h3 id="compare-panel-title" style="margin:0 0 4px;font-size:1.1rem">工具对比</h3>
    <div id="compare-panel-body"></div>
  </div>
</div>

<style>
  .page-desc {
    color: var(--text-dim);
    margin-top: 0.25rem;
    font-size: 0.95rem;
  }
  .page-desc a { color: var(--accent); font-size: 0.875rem; }

  /* ── 顶部搜索 + 分类 bar ── */
  .tools-top-bar {
    margin-bottom: 20px;
  }
  .tools-search-wrap {
    position: relative;
    display: flex;
    align-items: center;
    margin-bottom: 12px;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }
  .tools-search-icon {
    position: absolute;
    left: 0.75rem;
    width: 15px; height: 15px;
    color: var(--text-dim);
    pointer-events: none;
  }
  .tools-search-input {
    width: 100%;
    padding: 0.6rem 0.8rem 0.6rem 2.3rem;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    background: var(--bg-card);
    color: var(--text);
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .tools-search-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(79,172,254,0.12);
  }
  .tools-search-input::placeholder { color: var(--text-dim); }
  .tools-search-count {
    margin-left: 10px;
    font-size: 0.75rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
    white-space: nowrap;
  }
  .tools-cat-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 6px;
  }
  .cat-btn {
    padding: 4px 12px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    font-size: 0.8rem;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .cat-btn:hover { border-color: var(--accent); color: var(--accent); }
  .cat-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 500; }

  .tools-price-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .price-btn {
    padding: 4px 12px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    font-size: 0.8rem;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .price-btn:hover { border-color: var(--accent); color: var(--accent); }
  .price-btn.active { background: rgba(79,172,254,0.12); border-color: var(--accent); color: var(--accent); font-weight: 500; }

  /* ── 精选区块 ── */
  .featured-section {
    margin-bottom: 2rem;
    background: rgba(79,172,254,0.03);
    border: 1px solid rgba(79,172,254,0.1);
    border-radius: 14px;
    padding: 14px 16px;
  }
  .featured-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .sort-btn {
    padding: 4px 14px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    font-size: 0.82rem;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .sort-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 500; }
  .featured-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  @media (max-width: 1200px) { .featured-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 900px)  { .featured-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px)  { .featured-grid { grid-template-columns: repeat(2, 1fr); } }

  /* ── 主内容区 ── */
  .tools-main { min-width: 0; }

  /* section 区块：带分类底色 */
  .tool-section {
    margin-bottom: 2rem;
    background: rgba(var(--section-color-rgb, 79,172,254), 0.02);
    border: 1px solid rgba(var(--section-color-rgb, 79,172,254), 0.07);
    border-radius: 14px;
    padding: 18px 20px;
  }

  /* section 标题：左侧彩色竖线 + 底部彩色分割线 */
  .section-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.875rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid rgba(var(--section-color-rgb, 79,172,254), 0.2);
    color: var(--text);
    cursor: pointer;
    user-select: none;
  }
  .section-title:hover { color: var(--section-color, var(--accent)); }
  .section-chevron {
    margin-left: auto;
    flex-shrink: 0;
    transition: transform 0.2s;
    color: var(--text-dim);
  }
  .tool-section.collapsed .section-chevron { transform: rotate(-90deg); }
  .tool-section.collapsed .tool-grid { display: none; }
  .section-title-bar {
    display: inline-block;
    width: 4px;
    height: 1.1em;
    border-radius: 2px;
    background: var(--section-color, var(--accent));
    flex-shrink: 0;
  }

  .tool-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  @media (max-width: 1200px) { .tool-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px)  { .tool-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px)  { .tool-grid { grid-template-columns: 1fr; } }

  .tool-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: linear-gradient(160deg, rgba(var(--section-color-rgb,79,172,254),0.05) 0%, var(--bg-card) 55%);
    border: 1px solid rgba(var(--section-color-rgb,79,172,254),0.13);
    border-top: 3px solid var(--section-color, var(--accent));
    border-radius: 10px;
    transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .tool-card:hover {
    background: linear-gradient(160deg, rgba(var(--section-color-rgb,79,172,254),0.1) 0%, var(--bg-card) 60%);
    border-color: var(--section-color, var(--accent));
    transform: translateY(-3px);
    box-shadow: 0 10px 40px rgba(var(--section-color-rgb,79,172,254),0.14);
  }
  .tool-card.comparing {
    border-color: var(--section-color, var(--accent));
    box-shadow: 0 0 0 2px var(--section-color, var(--accent));
  }

  /* Badge */
  .tool-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 10px;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 999px;
    color: #fff;
    letter-spacing: 0.03em;
    pointer-events: none;
  }
  .badge-free     { background: linear-gradient(90deg, #43e97b, #38f9d7); }
  .badge-paid     { background: linear-gradient(90deg, #A855F7, #6366F1); }
  .badge-freemium { background: linear-gradient(90deg, #4FACFE, #00F2FE); }

  .tool-card-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 12px 12px 8px;
    flex: 1;
    text-decoration: none;
    color: inherit;
  }
  .tool-card-link:hover { text-decoration: none; }

  .tool-favicon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    margin-bottom: 7px;
    flex-shrink: 0;
  }
  .tool-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 4px;
    transition: color 0.15s;
  }
  .tool-card:hover .tool-name { color: var(--section-color, var(--accent)); }

  .tool-desc {
    font-size: 11.5px;
    color: var(--text-dim);
    line-height: 1.45;
    flex: 1;
    margin-bottom: 24px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Compare button — right bottom corner */
  .compare-btn {
    position: absolute;
    bottom: 6px;
    right: 8px;
    padding: 2px 8px;
    border: 1px solid rgba(var(--section-color-rgb,79,172,254),0.3);
    border-radius: 4px;
    background: transparent;
    color: var(--text-dim);
    font-size: 11px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .compare-btn:hover { background: rgba(var(--section-color-rgb,79,172,254),0.08); color: var(--section-color, var(--accent)); border-color: var(--section-color, var(--accent)); }
  .compare-btn.selected { background: rgba(var(--section-color-rgb,79,172,254),0.15); color: var(--section-color, var(--accent)); border-color: var(--section-color, var(--accent)); }

  .tool-card.hidden { display: none; }
  .tool-section.section-hidden { display: none; }

  /* Compare bar */
  #compare-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    padding: 12px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    z-index: 100;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.15);
  }
  .compare-bar-items { display: flex; gap: 8px; flex: 1; flex-wrap: wrap; }
  .compare-bar-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: rgba(79,172,254,0.1);
    border: 1px solid rgba(79,172,254,0.3);
    border-radius: 999px;
    font-size: 13px;
    color: var(--text);
  }
  .compare-bar-chip button {
    background: none; border: none; cursor: pointer;
    color: var(--text-dim); font-size: 14px; line-height: 1; padding: 0;
  }
  .compare-bar-chip button:hover { color: var(--text); }
  #compare-start-btn {
    padding: 7px 20px;
    background: linear-gradient(90deg, #4FACFE, #00F2FE);
    border: none; border-radius: 8px;
    color: #fff; font-size: 13px; font-weight: 600;
    cursor: pointer; white-space: nowrap;
  }
  #compare-close-bar {
    background: none; border: none; cursor: pointer;
    color: var(--text-dim); font-size: 18px; padding: 0 4px;
  }

  /* Compare panel */
  #compare-panel {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .compare-panel-inner {
    background: var(--bg-card);
    border-radius: 14px;
    width: 100%;
    max-width: 860px;
    max-height: 80vh;
    overflow-y: auto;
    padding: 24px;
    position: relative;
  }
  #compare-panel-close {
    position: absolute; top: 16px; right: 16px;
    background: none; border: none; cursor: pointer;
    color: var(--text-dim); font-size: 22px;
  }
  .compare-table { width: 100%; border-collapse: collapse; margin-top: 16px; }
  .compare-table th, .compare-table td {
    padding: 10px 14px;
    border: 1px solid var(--border);
    font-size: 13px;
    text-align: left;
    vertical-align: top;
  }
  .compare-table th { background: rgba(79,172,254,0.06); font-weight: 600; color: var(--text); }
  .compare-table td { color: var(--text-dim); }

  /* ── 移动端 ── */
  @media (max-width: 600px) {
    .tools-search-input { max-width: 100%; }
  }

  /* ── 浮动侧边栏 ── */
  .sticky-sidebar {
    position: fixed;
    left: 52px;
    top: 50%;
    transform: translateY(-50%) translateX(-16px);
    width: 160px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 10px;
    z-index: 80;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .sticky-sidebar.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(-50%) translateX(0);
  }
  .sticky-search-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 8px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    margin-bottom: 8px;
    color: var(--text-dim);
  }
  .sticky-search-input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--text);
    font-size: 0.8rem;
    outline: none;
    min-width: 0;
  }
  .sticky-search-input::placeholder { color: var(--text-dim); }
  .sticky-cat-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
    max-height: calc(100vh - 200px);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .sticky-cat-nav::-webkit-scrollbar { display: none; }
  .sticky-cat-btn {
    text-align: left;
    padding: 5px 8px;
    border-radius: 5px;
    border: none;
    background: transparent;
    color: var(--text-dim);
    font-size: 0.78rem;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sticky-cat-btn:hover { background: rgba(79,172,254,0.08); color: var(--accent); }
  .sticky-cat-btn.active { background: rgba(79,172,254,0.12); color: var(--accent); font-weight: 500; }

  @media (max-width: 768px) { .sticky-sidebar { display: none; } }
</style>

<script>
  const input = document.getElementById('tools-search-input') as HTMLInputElement;
  const countEl = document.getElementById('tools-search-count')!;
  const sections = Array.from(document.querySelectorAll<HTMLElement>('.tool-section'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.tool-card:not(.featured-card)'));

  const cardTexts = cards.map(card => {
    const name = card.querySelector('.tool-name')?.textContent ?? '';
    const desc = card.querySelector('.tool-desc')?.textContent ?? '';
    return (name + ' ' + desc).toLowerCase();
  });

  let activeCategory = 'all';
  let activePrice = 'all';

  function applyFilters() {
    const q = input.value.trim().toLowerCase();
    let matched = 0;
    cards.forEach((card, i) => {
      const catMatch = activeCategory === 'all' || card.closest('.tool-section')?.id === activeCategory;
      const priceMatch = activePrice === 'all' || (card as HTMLElement).dataset.tag === activePrice;
      const textMatch = !q || cardTexts[i].includes(q);
      if (catMatch && priceMatch && textMatch) { card.classList.remove('hidden'); matched++; }
      else card.classList.add('hidden');
    });
    sections.forEach(sec => {
      sec.classList.toggle('section-hidden', sec.querySelectorAll('.tool-card:not(.hidden)').length === 0);
    });
    if (q) { countEl.textContent = `找到 ${matched} 个工具`; countEl.style.display = ''; }
    else countEl.style.display = 'none';
  }

  input.addEventListener('input', applyFilters);
  input.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') { input.value = ''; applyFilters(); }
  });

  // Category filter
  document.querySelectorAll<HTMLButtonElement>('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.cat ?? 'all';
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.toggle('active', b === btn));
      applyFilters();
    });
  });

  // Price filter
  document.querySelectorAll<HTMLButtonElement>('.price-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activePrice = btn.dataset.price ?? 'all';
      document.querySelectorAll('.price-btn').forEach(b => b.classList.toggle('active', b === btn));
      applyFilters();
    });
  });

  // Sort (popular/latest)
  document.querySelectorAll<HTMLButtonElement>('.sort-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const sort = btn.dataset.sort!;
      document.querySelectorAll('.sort-btn').forEach(b => b.classList.toggle('active', b === btn));
      document.querySelectorAll<HTMLElement>('.featured-card').forEach(card => {
        card.style.display = card.dataset.sort === sort ? '' : 'none';
      });
    });
  });

  // Sticky sidebar visibility
  const stickySidebar = document.getElementById('sticky-sidebar')!;
  const topBar = document.querySelector<HTMLElement>('.tools-top-bar')!;
  const stickySearchInput = document.getElementById('sticky-search-input') as HTMLInputElement;

  const topBarObserver = new IntersectionObserver(([entry]) => {
    stickySidebar.classList.toggle('visible', !entry.isIntersecting);
  }, { threshold: 0 });
  topBarObserver.observe(topBar);

  // Sticky search syncs with main search
  stickySearchInput.addEventListener('input', () => {
    input.value = stickySearchInput.value;
    input.dispatchEvent(new Event('input'));
  });
  input.addEventListener('input', () => {
    if (stickySearchInput.value !== input.value) stickySearchInput.value = input.value;
  });

  // Sticky cat buttons sync with main cat buttons
  document.querySelectorAll<HTMLButtonElement>('.sticky-cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.cat ?? 'all';
      document.querySelectorAll('.cat-btn').forEach(b =>
        b.classList.toggle('active', (b as HTMLElement).dataset.cat === activeCategory)
      );
      document.querySelectorAll('.sticky-cat-btn').forEach(b =>
        b.classList.toggle('active', b === btn)
      );
      applyFilters();
    });
  });

  // Keep sticky buttons in sync when main buttons are clicked
  const origCatBtnHandler = () => {
    document.querySelectorAll('.sticky-cat-btn').forEach(b =>
      b.classList.toggle('active', (b as HTMLElement).dataset.cat === activeCategory)
    );
  };
  document.querySelectorAll<HTMLButtonElement>('.cat-btn').forEach(btn => {
    btn.addEventListener('click', origCatBtnHandler);
  });

  // Section collapse
  document.querySelectorAll<HTMLElement>('[data-collapse-toggle]').forEach(title => {
    title.addEventListener('click', () => {
      title.closest('.tool-section')?.classList.toggle('collapsed');
    });
  });

  // Compare
  type CompareItem = { slug: string; name: string; desc: string; tag: string; favicon: string };
  let compareList: CompareItem[] = [];

  const compareData: Record<string, any> = JSON.parse(
    document.getElementById('compare-data')?.textContent ?? '{}'
  );

  const bar = document.getElementById('compare-bar')!;
  const barItems = document.getElementById('compare-bar-items')!;
  const startBtn = document.getElementById('compare-start-btn')!;
  const closeBar = document.getElementById('compare-close-bar')!;
  const panel = document.getElementById('compare-panel')!;
  const panelBody = document.getElementById('compare-panel-body')!;
  const panelClose = document.getElementById('compare-panel-close')!;
  const panelTitle = document.getElementById('compare-panel-title')!;

  const toast = document.createElement('div');
  toast.style.cssText = 'position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:#1a1a2e;color:#fff;font-size:13px;padding:8px 18px;border-radius:8px;z-index:300;pointer-events:none;opacity:0;transition:opacity 0.2s';
  document.body.appendChild(toast);
  function showToast(msg: string) {
    toast.textContent = msg; toast.style.opacity = '1';
    setTimeout(() => { toast.style.opacity = '0'; }, 2000);
  }

  function renderBar() {
    bar.style.display = compareList.length > 0 ? 'flex' : 'none';
    barItems.innerHTML = compareList.map(item => `
      <span class="compare-bar-chip">
        <img src="${item.favicon}" width="16" height="16" style="border-radius:4px;flex-shrink:0" alt="" />
        ${item.name}<button data-slug="${item.slug}">×</button>
      </span>
    `).join('');
    barItems.querySelectorAll<HTMLButtonElement>('button[data-slug]').forEach(btn => {
      btn.addEventListener('click', () => removeCompare(btn.dataset.slug!));
    });
  }

  function removeCompare(slug: string) {
    compareList = compareList.filter(i => i.slug !== slug);
    document.querySelectorAll<HTMLElement>(`.tool-card[data-slug="${slug}"]`).forEach(card => {
      card.classList.remove('comparing');
      const btn = card.querySelector<HTMLButtonElement>('.compare-btn');
      if (btn) { btn.textContent = '+ 对比'; btn.classList.remove('selected'); }
    });
    renderBar();
  }

  document.querySelectorAll<HTMLButtonElement>('.compare-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest<HTMLElement>('.tool-card')!;
      const slug = btn.dataset.slug!;
      const name = btn.dataset.name!;
      if (compareList.findIndex(i => i.slug === slug) >= 0) { removeCompare(slug); return; }
      if (compareList.length >= 3) { showToast('最多对比 3 个工具'); return; }
      const desc = card.querySelector('.tool-desc')?.textContent ?? '';
      const tag = card.dataset.tag ?? card.querySelector('.tool-badge')?.textContent ?? '';
      const favicon = (card.querySelector('.tool-favicon') as HTMLImageElement)?.src ?? '';
      compareList.push({ slug, name, desc, tag, favicon });
      document.querySelectorAll<HTMLElement>(`.tool-card[data-slug="${slug}"]`).forEach(c => c.classList.add('comparing'));
      btn.textContent = '✓ 已选';
      btn.classList.add('selected');
      renderBar();
    });
  });

  closeBar.addEventListener('click', () => { [...compareList.map(i => i.slug)].forEach(removeCompare); });

  const POPULAR = new Set(['chatgpt','cursor','midjourney','claude','github-copilot','notion-ai','perplexity','canva-ai']);
  const LATEST  = new Set(['bolt-new','v0','devin','sora','grok','gemini','copilot','perplexity']);

  startBtn.addEventListener('click', () => {
    const count = compareList.length;
    panelTitle.textContent = `对比 ${count} 个工具`;

    function stars(slug: string) {
      return POPULAR.has(slug) ? '★★★★★' : LATEST.has(slug) ? '★★★★☆' : '★★★☆☆';
    }
    function audience(d: any) {
      const m = (d.longDesc ?? '').match(/适合([^。.]+)/);
      return m ? m[1].trim() : (d.category ?? '—');
    }
    function company(url: string) {
      try { return new URL(url).hostname.replace(/^www\./, ''); } catch { return '—'; }
    }
    function tagBadge(tag: string) {
      const cls = tag === '免费' ? 'background:rgba(67,233,123,0.15);color:#10B981;border:1px solid rgba(67,233,123,0.4)'
                : tag === '付费' ? 'background:rgba(168,85,247,0.12);color:#A855F7;border:1px solid rgba(168,85,247,0.35)'
                : 'background:rgba(79,172,254,0.12);color:#4FACFE;border:1px solid rgba(79,172,254,0.35)';
      return `<span style="display:inline-block;font-size:11px;font-weight:600;padding:2px 9px;border-radius:999px;${cls}">${tag}</span>`;
    }

    const headerCells = compareList.map(item => {
      const d = compareData[item.slug] ?? {};
      return `<th style="padding:14px 16px;text-align:center;border-left:1px solid var(--border);min-width:160px;vertical-align:bottom">
        <img src="${item.favicon}" width="40" height="40" style="border-radius:10px;display:block;margin:0 auto 8px" alt="${item.name}" />
        <div style="font-size:11px;font-weight:700;letter-spacing:.07em;color:var(--text-dim);margin-bottom:6px">${item.name.toUpperCase()}</div>
        <a href="${d.url ?? '#'}" target="_blank" rel="noopener" style="font-size:11px;color:var(--accent);text-decoration:none;border:1px solid rgba(79,172,254,0.3);border-radius:4px;padding:2px 8px">访问 ↗</a>
      </th>`;
    }).join('');

    const rowDefs = [
      { label: '简介',    fn: (d: any) => `<span style="color:var(--text)">${(d.longDesc ?? '').split(/[。.]/)[0].trim()}。</span>` },
      { label: '适合人群', fn: (d: any) => audience(d) },
      { label: '所属公司', fn: (d: any) => company(d.url ?? '') },
      { label: '分类',    fn: (d: any) => d.category ?? '—' },
      { label: '定价',    fn: (_d: any, item: CompareItem) => tagBadge(item.tag) },
      { label: '流行度',  fn: (_d: any, item: CompareItem) => `<span style="color:#F59E0B;letter-spacing:2px">${stars(item.slug)}</span>` },
      { label: '最大优点', fn: (d: any) => d.pros?.[0] ? `<span style="color:#10B981">✓ ${d.pros[0]}</span>` : '—' },
      { label: '主要缺点', fn: (d: any) => d.cons?.[0] ? `<span style="color:#EF4444">✗ ${d.cons[0]}</span>` : '—' },
    ];

    const bodyRows = rowDefs.map(row => {
      const cells = compareList.map(item => {
        const d = compareData[item.slug] ?? {};
        return `<td style="padding:10px 16px;font-size:13px;color:var(--text-dim);line-height:1.5;border-left:1px solid var(--border);border-top:1px solid var(--border);vertical-align:top">${row.fn(d, item)}</td>`;
      }).join('');
      return `<tr>
        <th style="padding:10px 14px;font-size:11px;font-weight:600;color:var(--text-dim);text-transform:uppercase;letter-spacing:.05em;white-space:nowrap;background:rgba(79,172,254,0.03);text-align:left;width:90px;border-top:1px solid var(--border)">${row.label}</th>
        ${cells}
      </tr>`;
    }).join('');

    panelBody.innerHTML = `
      <table style="width:100%;border-collapse:collapse;margin-top:4px">
        <thead><tr><th style="width:90px"></th>${headerCells}</tr></thead>
        <tbody>${bodyRows}</tbody>
      </table>`;
    panel.style.display = 'flex';
  });

  panelClose.addEventListener('click', () => { panel.style.display = 'none'; });
  panel.addEventListener('click', (e) => { if (e.target === panel) panel.style.display = 'none'; });
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && panel.style.display !== 'none') panel.style.display = 'none';
  });
</script>

