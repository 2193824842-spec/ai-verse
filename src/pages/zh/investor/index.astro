---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { TOOLS } from '../../../data/tools';

const allPosts = await getCollection('posts-zh');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const insightPosts = allPosts
  .filter(p => (p.data as any).category === 'industry-insights')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const trendingPosts = allPosts
  .filter(p => (p.data as any).category === 'trending')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredMain   = insightPosts[0] ?? null;
const featuredSide   = insightPosts.slice(1, 3);
const latestTrending = trendingPosts.slice(0, 3);

const featuredTools = TOOLS.slice(0, 6).map(g => g.items[0]);

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
}
---

<BaseLayout title="投资者视角 · AI Verse" description="聚焦 AI 市场格局、融资动态、技术演进，帮助投资者和行业观察者把握趋势。" lang="zh">

  <!-- Hero -->
  <section class="inv-hero">
    <div class="inv-eyebrow">📊 AI 行业投资情报</div>
    <h1 class="inv-h1">读懂 AI 行业<br>比别人早一步</h1>
    <p class="inv-sub">聚焦 AI 市场格局、融资动态、技术演进，帮助投资者和行业观察者把握趋势。</p>
  </section>

  <!-- Stats -->
  <div class="inv-stats">
    <div class="inv-stat">
      <div class="inv-stat-value">{insightPosts.length}</div>
      <div class="inv-stat-label">行业洞察文章</div>
    </div>
    <div class="inv-stat">
      <div class="inv-stat-value">{trendingPosts.length}</div>
      <div class="inv-stat-label">热点解析文章</div>
    </div>
    <div class="inv-stat">
      <div class="inv-stat-value">每周</div>
      <div class="inv-stat-label">更新频率</div>
    </div>
    <div class="inv-stat">
      <div class="inv-stat-value">2026</div>
      <div class="inv-stat-label">持续追踪中</div>
    </div>
  </div>

  <!-- 精选深度 -->
  <section class="inv-section">
    <div class="inv-section-header">
      <div class="inv-section-title">精选深度</div>
      <a href={`${base}/zh/articles/?cat=insight`} class="inv-see-all">全部行业洞察 →</a>
    </div>

    {insightPosts.length === 0 ? (
      <div class="inv-empty">行业洞察文章即将上线，敬请期待。</div>
    ) : (
      <div class="inv-featured-grid">
        {featuredMain && (
          <a href={`${base}/zh/posts/${featuredMain.slug}/`} class="inv-featured-card">
            {(featuredMain.data as any).cover
              ? <img src={(featuredMain.data as any).cover} alt={featuredMain.data.title} class="inv-featured-cover-img" />
              : <div class="inv-featured-cover">🏭</div>
            }
            <div class="inv-featured-body">
              <div class="inv-card-meta">
                <span class="inv-tag inv-tag--insight">行业洞察</span>
                <span class="inv-card-date">{formatDate(featuredMain.data.date)}</span>
              </div>
              <div class="inv-featured-title">{featuredMain.data.title}</div>
              {(featuredMain.data as any).summary && (
                <div class="inv-featured-summary">{(featuredMain.data as any).summary}</div>
              )}
            </div>
          </a>
        )}
        {featuredSide.length > 0 && (
          <div class="inv-side-cards">
            {featuredSide.map(p => (
              <a href={`${base}/zh/posts/${p.slug}/`} class="inv-side-card">
                <div class="inv-card-meta">
                  <span class="inv-tag inv-tag--insight">行业洞察</span>
                  <span class="inv-card-date">{formatDate(p.data.date)}</span>
                </div>
                <div class="inv-card-title">{p.data.title}</div>
              </a>
            ))}
          </div>
        )}
      </div>
    )}
  </section>

  <!-- 最新热点 -->
  <section class="inv-section">
    <div class="inv-section-header">
      <div class="inv-section-title">最新热点</div>
      <a href={`${base}/zh/articles/?cat=trending`} class="inv-see-all">全部热点解析 →</a>
    </div>

    {trendingPosts.length === 0 ? (
      <div class="inv-empty">热点解析文章即将上线，敬请期待。</div>
    ) : (
      <div class="inv-articles-grid">
        {latestTrending.map(p => (
          <a href={`${base}/zh/posts/${p.slug}/`} class="inv-article-card">
            {(p.data as any).cover
              ? <img src={(p.data as any).cover} alt={p.data.title} class="inv-card-cover-img" />
              : <div class="inv-card-cover">⚡</div>
            }
            <div class="inv-card-body">
              <div class="inv-card-meta">
                <span class="inv-tag inv-tag--trending">热点解析</span>
                <span class="inv-card-date">{formatDate(p.data.date)}</span>
              </div>
              <div class="inv-card-title">{p.data.title}</div>
              {(p.data as any).summary && (
                <div class="inv-card-summary">{(p.data as any).summary}</div>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <!-- 热门工具追踪 -->
  <section class="inv-section">
    <div class="inv-section-header">
      <div class="inv-section-title">热门工具追踪</div>
      <a href={`${base}/zh/tools/`} class="inv-see-all">查看全部工具 →</a>
    </div>
    <div class="inv-tools-grid">
      {featuredTools.map(tool => (
        <a href={`${base}/zh/tools/${tool.slug}/`} class="inv-tool-card">
          <div class="inv-tool-header">
            <span class="inv-tool-name">{tool.name}</span>
            <span class="inv-tool-tag">{tool.tag}</span>
          </div>
          <div class="inv-tool-category">{tool.category}</div>
          <div class="inv-tool-desc">{tool.desc}</div>
        </a>
      ))}
    </div>
  </section>
  <!-- 资讯入口 -->
  <section class="inv-section">
    <a href={`${base}/zh/news/`} class="inv-news-banner">
      <div class="inv-news-left">
        <div class="inv-news-title">📰 每日 AI 资讯</div>
        <div class="inv-news-desc">聚合 36氪、爱范儿、钛媒体等媒体的 AI 行业动态，每日更新</div>
      </div>
      <div class="inv-news-arrow">查看资讯 →</div>
    </a>
  </section>

</BaseLayout>

<style>
  /* ── 投资者专属 CSS 变量 ── */
  :root {
    --inv-gold:  #F59E0B;
    --inv-green: #10B981;
  }
  [data-theme="light"] {
    --inv-gold:  #d97706;
    --inv-green: #059669;
  }

  /* ── Hero ── */
  .inv-hero { padding: 40px 0 32px; text-align: center; }
  .inv-eyebrow {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.25);
    color: var(--inv-gold); font-size: 13px; padding: 4px 14px;
    border-radius: 20px; margin-bottom: 20px;
  }
  .inv-h1 {
    font-size: 36px; font-weight: 800; line-height: 1.2; margin-bottom: 16px;
    background: linear-gradient(135deg, #F59E0B 0%, #10B981 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .inv-sub { color: var(--text-dim); font-size: 16px; max-width: 500px; margin: 0 auto; }

  /* ── Stats ── */
  .inv-stats {
    display: flex; justify-content: center; gap: 48px;
    padding: 24px 0;
    border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    margin: 32px 0 48px;
  }
  @media (max-width: 600px) { .inv-stats { gap: 24px; flex-wrap: wrap; } }
  .inv-stat { text-align: center; }
  .inv-stat-value { font-size: 28px; font-weight: 700; color: var(--inv-gold); }
  .inv-stat-label { font-size: 13px; color: var(--text-dim); margin-top: 2px; }

  /* ── Section ── */
  .inv-section { margin-bottom: 52px; }
  .inv-section-header {
    display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;
  }
  .inv-section-title {
    font-size: 18px; font-weight: 700;
    display: flex; align-items: center; gap: 8px;
  }
  .inv-section-title::before {
    content: ''; display: inline-block; width: 4px; height: 18px;
    background: linear-gradient(to bottom, #F59E0B, #10B981); border-radius: 2px;
  }
  .inv-see-all {
    font-size: 13px; color: var(--text-dim);
    border: 1px solid var(--border); padding: 5px 14px; border-radius: 20px;
    transition: border-color 0.15s, color 0.15s;
  }
  .inv-see-all:hover { color: var(--text); border-color: var(--inv-gold); text-decoration: none; }

  /* ── Empty state ── */
  .inv-empty {
    padding: 48px 0; text-align: center;
    color: var(--text-dim); font-size: 14px;
    border: 1px dashed var(--border); border-radius: 10px;
  }

  /* ── Tags ── */
  .inv-tag {
    font-size: 11px; padding: 2px 8px; border-radius: 10px; font-weight: 600;
    font-family: var(--font-mono);
  }
  .inv-tag--insight {
    background: rgba(245,158,11,0.12); color: var(--inv-gold);
    border: 1px solid rgba(245,158,11,0.3);
  }
  .inv-tag--trending {
    background: rgba(16,185,129,0.12); color: var(--inv-green);
    border: 1px solid rgba(16,185,129,0.3);
  }
  .inv-card-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .inv-card-date { font-size: 12px; color: var(--text-dim); font-family: var(--font-mono); }

  /* ── Featured grid ── */
  .inv-featured-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }
  @media (max-width: 700px) { .inv-featured-grid { grid-template-columns: 1fr; } }

  .inv-featured-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
    overflow: hidden; display: block; color: inherit; text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .inv-featured-card:hover {
    border-color: var(--inv-gold);
    box-shadow: 0 8px 32px rgba(245,158,11,0.12);
    text-decoration: none;
  }
  .inv-featured-cover {
    height: 200px; background: linear-gradient(135deg, #1a1500, #0a1a10);
    display: flex; align-items: center; justify-content: center; font-size: 56px;
  }
  .inv-featured-cover-img { width: 100%; height: 200px; object-fit: cover; display: block; }
  .inv-featured-body { padding: 20px; }
  .inv-featured-title {
    font-size: 17px; font-weight: 700; line-height: 1.4; margin: 8px 0;
    color: var(--text);
  }
  .inv-featured-card:hover .inv-featured-title { color: var(--inv-gold); }
  .inv-featured-summary { font-size: 14px; color: var(--text-dim); line-height: 1.6; }

  .inv-side-cards { display: flex; flex-direction: column; gap: 16px; }
  .inv-side-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
    padding: 16px 18px; flex: 1; display: block; color: inherit; text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .inv-side-card:hover {
    border-color: var(--inv-gold);
    box-shadow: 0 8px 32px rgba(245,158,11,0.1);
    text-decoration: none;
  }
  .inv-side-card:hover .inv-card-title { color: var(--inv-gold); }

  /* ── Article grid ── */
  .inv-articles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  @media (max-width: 860px) { .inv-articles-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .inv-articles-grid { grid-template-columns: 1fr; } }

  .inv-article-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
    overflow: hidden; display: block; color: inherit; text-decoration: none;
    transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .inv-article-card:hover {
    border-color: var(--inv-gold); transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(245,158,11,0.12); text-decoration: none;
  }
  .inv-article-card:hover .inv-card-title { color: var(--inv-gold); }
  .inv-card-cover {
    height: 140px; background: linear-gradient(135deg, #1a2035, #0f1a2e);
    display: flex; align-items: center; justify-content: center; font-size: 36px;
  }
  .inv-card-cover-img { width: 100%; height: 140px; object-fit: cover; display: block; }
  .inv-card-body { padding: 14px 16px 16px; }
  .inv-card-title {
    font-size: 14px; font-weight: 600; color: var(--text); line-height: 1.45;
    margin-bottom: 6px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    transition: color 0.15s;
  }
  .inv-card-summary {
    font-size: 13px; color: var(--text-dim); line-height: 1.5;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .inv-tools-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }
  @media (max-width: 860px) { .inv-tools-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .inv-tools-grid { grid-template-columns: 1fr; } }

  .inv-tool-card {
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
    padding: 16px 18px; display: block; color: inherit; text-decoration: none;
    transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .inv-tool-card:hover {
    border-color: var(--inv-gold); transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(245,158,11,0.1); text-decoration: none;
  }
  .inv-tool-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 4px;
  }
  .inv-tool-name { font-size: 15px; font-weight: 600; color: var(--text); }
  .inv-tool-card:hover .inv-tool-name { color: var(--inv-gold); }
  .inv-tool-tag {
    font-size: 11px; padding: 1px 7px; border-radius: 10px;
    background: rgba(245,158,11,0.1); color: var(--inv-gold);
    border: 1px solid rgba(245,158,11,0.25); font-family: var(--font-mono);
    white-space: nowrap;
  }
  .inv-tool-category { font-size: 11px; color: var(--text-dim); margin-bottom: 8px; font-family: var(--font-mono); }
  .inv-tool-desc { font-size: 13px; color: var(--text-dim); line-height: 1.5; }
  .inv-news-banner {
    display: flex; align-items: center; justify-content: space-between;
    background: var(--bg-card); border: 1px solid rgba(245,158,11,0.3);
    border-radius: 10px; padding: 20px 24px;
    text-decoration: none; color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    background-image: linear-gradient(135deg, rgba(245,158,11,0.05) 0%, transparent 60%);
  }
  .inv-news-banner:hover {
    border-color: var(--inv-gold); transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(245,158,11,0.12); text-decoration: none;
  }
  .inv-news-title { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
  .inv-news-desc { font-size: 13px; color: var(--text-dim); }
  .inv-news-arrow { font-size: 14px; color: var(--inv-gold); font-weight: 600; white-space: nowrap; margin-left: 24px; }
</style>
