---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts-en');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const CATEGORIES = [
  { name: 'All',         slug: 'all',     keywords: [] },
  { name: 'AI Coding',   slug: 'coding',  keywords: ['Coding', 'Cursor', 'Copilot', 'Windsurf', 'CodeGeeX', 'Trae', 'Claude Code'] },
  { name: 'AI Models',   slug: 'models',  keywords: ['ChatGPT', 'Claude', 'DeepSeek', 'Gemini', 'LLM'] },
  { name: 'AI Image',    slug: 'image',   keywords: ['Image', 'Midjourney', 'DALL', 'Stable Diffusion'] },
  { name: 'AI Writing',  slug: 'writing', keywords: ['Writing', 'Copywriting'] },
  { name: 'General',     slug: 'general', keywords: [] },
];

function matchCat(tags: string[]): string {
  const s = tags.join(' ');
  for (const c of CATEGORIES) {
    if (c.slug === 'all' || c.slug === 'general') continue;
    if (c.keywords.some(k => s.includes(k))) return c.slug;
  }
  return 'general';
}

const grouped: Record<string, typeof allPosts> = {};
for (const c of CATEGORIES) grouped[c.slug] = [];
for (const p of allPosts) {
  const slug = matchCat(p.data.tags || []);
  grouped[slug].push(p);
  grouped['all'].push(p);
}
for (const slug of Object.keys(grouped))
  grouped[slug].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tagCount = new Map<string, number>();
for (const p of allPosts)
  for (const t of p.data.tags || [])
    tagCount.set(t, (tagCount.get(t) ?? 0) + 1);

const catTags: Record<string, string[]> = { all: [] };
for (const c of CATEGORIES) catTags[c.slug] = [];
for (const p of allPosts) {
  const slug = matchCat(p.data.tags || []);
  for (const t of p.data.tags || []) {
    if ((tagCount.get(t) ?? 0) >= 2) {
      if (!catTags[slug].includes(t)) catTags[slug].push(t);
      if (!catTags['all'].includes(t)) catTags['all'].push(t);
    }
  }
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

const groupedSlugs = Object.fromEntries(
  Object.entries(grouped).map(([k, v]) => [k, v.map(p => p.slug)])
);
const postMeta = Object.fromEntries(
  allPosts.map(p => [p.slug, {
    title: p.data.title,
    date: formatDate(p.data.date),
    tags: p.data.tags,
    summary: p.data.summary ?? '',
    cover: p.data.cover ?? '',
    href: `${base}/en/posts/${p.slug}/`,
  }])
);
---

<BaseLayout title="Article Index · AI Verse" description="Browse all AI tools reviews and tutorials by category and tag." lang="en">

  <div class="page-header">
    <h1>Article Index</h1>
    <p class="page-desc">{allPosts.length} articles</p>
  </div>

  <nav class="cat-tabs" id="cat-tabs">
    {CATEGORIES.filter(c => c.slug === 'all' || grouped[c.slug].length > 0).map((cat, i) => (
      <button class={`cat-tab${i === 0 ? ' active' : ''}`} data-cat={cat.slug}>
        {cat.name}
        <span class="tab-count">{grouped[cat.slug].length}</span>
      </button>
    ))}
  </nav>

  <div class="tag-bar" id="tag-bar"></div>

  <!-- Search box -->
  <div class="article-search-wrap">
    <svg class="article-search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    <input id="article-search" class="article-search-input" type="search" placeholder="Search articles…" autocomplete="off" />
    <button id="article-search-btn" class="article-search-btn" aria-label="Search">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    </button>
  </div>

  <ul class="post-list" id="post-list"></ul>

</BaseLayout>

<script define:vars={{ groupedSlugs, postMeta, catTags }}>
  let currentCat = 'all';
  let currentTag = '';
  let currentSearch = '';

  const tabsEl   = document.getElementById('cat-tabs');
  const tagBarEl = document.getElementById('tag-bar');
  const listEl   = document.getElementById('post-list');
  const searchEl = document.getElementById('article-search');

  function renderTags() {
    const tags = catTags[currentCat] || [];
    if (!tags.length) { tagBarEl.innerHTML = ''; return; }
    tagBarEl.innerHTML = tags.map(t =>
      `<button class="tag-chip${t === currentTag ? ' active' : ''}" data-tag="${t}">#${t}</button>`
    ).join('');
    tagBarEl.querySelectorAll('.tag-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        const t = btn.dataset.tag;
        currentTag = currentTag === t ? '' : t;
        renderTags();
        renderPosts();
      });
    });
  }

  function renderPosts() {
    let slugs = groupedSlugs[currentCat] || [];
    if (currentTag) slugs = slugs.filter(s => postMeta[s]?.tags?.includes(currentTag));
    if (currentSearch) {
      const q = currentSearch.toLowerCase();
      slugs = slugs.filter(s => {
        const p = postMeta[s];
        return p.title.toLowerCase().includes(q) || p.summary.toLowerCase().includes(q);
      });
    }
    if (!slugs.length) { listEl.innerHTML = '<li class="empty">No articles found.</li>'; return; }
    listEl.innerHTML = slugs.map(s => {
      const p = postMeta[s];
      return `
        <li class="post-card">
          <a href="${p.href}" class="post-card-link">
            <div class="post-card-cover-wrap">
              ${p.cover
                ? `<img src="${p.cover}" alt="${p.title}" class="post-card-cover" loading="lazy" />`
                : `<div class="post-card-cover post-card-cover--placeholder"></div>`
              }
            </div>
            <div class="post-card-body">
              <div class="post-card-meta">
                ${p.tags[0] ? `<span class="post-card-tag">#${p.tags[0]}</span>` : ''}
                <span class="post-card-date">${p.date}</span>
              </div>
              <h3 class="post-card-title">${p.title}</h3>
              ${p.summary ? `<p class="post-card-summary">${p.summary}</p>` : ''}
            </div>
          </a>
        </li>`;
    }).join('');
  }

  tabsEl.querySelectorAll('.cat-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      tabsEl.querySelectorAll('.cat-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentCat = btn.dataset.cat;
      currentTag = '';
      renderTags();
      renderPosts();
    });
  });

  renderTags();
  renderPosts();

  const searchBtnEl = document.getElementById('article-search-btn');

  function doSearch() {
    currentSearch = searchEl.value.trim();
    renderPosts();
  }

  searchBtnEl?.addEventListener('click', doSearch);
  searchEl?.addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(); });
</script>

<style is:global>
  .page-desc { color: var(--text-dim); font-size: 0.9rem; margin-top: 0.2rem; }

  /* ── Category tabs ── */
  .cat-tabs { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 1.5rem 0 1rem; }
  .cat-tab {
    display: flex; align-items: center; gap: 0.35rem;
    padding: 0.5rem 1.2rem; border: 1px solid var(--border); border-radius: 999px;
    background: var(--bg-card); font-size: 0.875rem; color: var(--text-dim); cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s, box-shadow 0.15s;
  }
  .cat-tab:hover { border-color: var(--accent); color: var(--accent); }
  .cat-tab.active {
    border-color: var(--accent); background: var(--accent); color: #fff;
    box-shadow: 0 2px 8px rgba(79,172,254,0.3);
  }
  .tab-count { font-size: 0.72rem; opacity: 0.8; }

  /* ── Tag bar (horizontal scroll) ── */
  .tag-bar {
    display: flex; flex-wrap: nowrap; overflow-x: auto; gap: 0.4rem;
    min-height: 1.5rem; margin-bottom: 1.5rem; padding-bottom: 2px;
    scrollbar-width: none; -ms-overflow-style: none;
  }
  .tag-bar::-webkit-scrollbar { display: none; }
  .tag-chip {
    padding: 0.18rem 0.65rem; border: 1px solid var(--border); border-radius: 4px;
    background: none; font-size: 0.75rem; color: var(--text-dim); cursor: pointer;
    white-space: nowrap; flex-shrink: 0;
    transition: border-color 0.15s, color 0.15s;
  }
  .tag-chip:hover, .tag-chip.active { border-color: var(--accent); color: var(--accent); }

  /* ── Card grid ── */
  .post-list {
    list-style: none; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  @media (max-width: 860px) { .post-list { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .post-list { grid-template-columns: 1fr; } }

  /* ── Card ── */
  .post-card {
    background: var(--bg-card); border: none; border-radius: 16px;
    overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  [data-theme="light"] .post-card { background: #fff; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
  .post-card:hover { transform: translateY(-4px); box-shadow: 0 10px 32px rgba(0,0,0,0.16); }
  [data-theme="light"] .post-card:hover { box-shadow: 0 10px 32px rgba(0,0,0,0.11); }

  .post-card-link { display: flex; flex-direction: column; height: 100%; text-decoration: none; color: inherit; }
  .post-card-link:hover { text-decoration: none; }
  .post-card-cover-wrap { width: 100%; aspect-ratio: 16/9; overflow: hidden; background: var(--border); }
  .post-card-cover { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.35s; }
  .post-card:hover .post-card-cover { transform: scale(1.05); }
  .post-card-cover--placeholder { width: 100%; height: 100%; background: var(--border); }

  .post-card-body { padding: 0.9rem 1.1rem 1.1rem; display: flex; flex-direction: column; flex: 1; }
  .post-card-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
  .post-card-tag { font-size: 0.7rem; color: var(--accent); background: rgba(88,166,255,0.1); border-radius: 4px; padding: 0.1rem 0.45rem; }
  .post-card-date { font-size: 0.68rem; color: var(--text-dim); opacity: 0.85; }
  .post-card-title {
    font-size: 0.92rem; font-weight: 600; margin: 0 0 0.45rem; color: var(--text); line-height: 1.55;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .post-card:hover .post-card-title { color: var(--accent); }
  .post-card-summary {
    font-size: 0.76rem; color: var(--text-dim); line-height: 1.55; margin: 0; opacity: 0.9;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .empty { padding: 2rem 0; color: var(--text-dim); font-size: 0.9rem; }

  /* ── Article search box ── */
  .article-search-wrap {
    position: relative;
    margin-bottom: 1.25rem;
  }
  .article-search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-dim);
    pointer-events: none;
  }
  .article-search-input {
    width: 100%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-size: 0.875rem;
    padding: 0.55rem 2.6rem 0.55rem 2.2rem;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .article-search-input::placeholder { color: var(--text-dim); }
  .article-search-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(79,172,254,0.12);
  }
  [data-theme="light"] .article-search-input:focus {
    box-shadow: 0 0 0 3px rgba(9,105,218,0.1);
  }
  .article-search-btn {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 38px;
    background: none;
    border: none;
    border-radius: 0 8px 8px 0;
    color: var(--text-dim);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s, background 0.15s;
  }
  .article-search-btn:hover {
    color: var(--accent);
    background: rgba(79,172,254,0.08);
  }
</style>
