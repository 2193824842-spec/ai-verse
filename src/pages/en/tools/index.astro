---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('tools-en');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Build inline compare data map: slug → rich fields
const compareDataMap: Record<string, {
  name: string; url: string; tag: string; category: string;
  longDesc: string; features: string[]; pricing: string; pros: string[]; cons: string[];
}> = {};
for (const e of entries) {
  compareDataMap[e.slug] = {
    name: e.data.name,
    url: e.data.url,
    tag: e.data.tag,
    category: e.data.category,
    longDesc: e.data.longDesc,
    features: e.data.features ?? [],
    pricing: e.data.pricing ?? '',
    pros: e.data.pros ?? [],
    cons: e.data.cons ?? [],
  };
}

const CATEGORY_ORDER = [
  'AI Coding Tools',
  'AI Models',
  'AI Writing Tools',
  'AI Image Generation',
  'AI Video Tools',
  'AI Productivity Tools',
  'AI Audio Tools',
];

const CATEGORY_SLUGS: Record<string, string> = {
  'AI Coding Tools':       'coding',
  'AI Models':             'models',
  'AI Writing Tools':      'writing',
  'AI Image Generation':   'image',
  'AI Video Tools':        'video',
  'AI Productivity Tools': 'productivity',
  'AI Audio Tools':        'audio',
};

const CATEGORY_COLORS: Record<string, string> = {
  coding:       '#4FACFE',
  models:       '#A855F7',
  writing:      '#10B981',
  image:        '#F59E0B',
  video:        '#EF4444',
  productivity: '#06B6D4',
  audio:        '#EC4899',
};

const TAG_COLORS: Record<string, string> = {
  'Free':      'tag-free',
  'Paid':      'tag-paid',
  'Free/Paid': 'tag-freemium',
};

const CATEGORY_ICONS: Record<string, string> = {
  coding:       `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  models:       `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>`,
  writing:      `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
  image:        `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
  video:        `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
  productivity: `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  audio:        `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
};

// Group by category
const grouped: Record<string, typeof entries> = {};
for (const entry of entries) {
  const cat = entry.data.category;
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(entry);
}

const sections = CATEGORY_ORDER
  .filter(cat => grouped[cat])
  .map(cat => ({
    category: cat,
    slug: CATEGORY_SLUGS[cat] ?? cat.toLowerCase(),
    items: grouped[cat],
  }));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "AI Tools Directory 2026",
  "description": "The most complete AI tools directory for 2026, covering AI coding, LLMs, writing, image generation, video generation and more.",
  "url": Astro.url.href,
};
---

<BaseLayout title="AI Tools Directory 2026 · Best AI Tools" description="The most complete AI tools directory for 2026, covering AI coding, LLMs, writing, image generation, video generation and more." lang="en">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div class="page-header">
    <h1>AI Tools Directory 2026</h1>
    <p class="page-desc">Curated AI tools, continuously updated · <a href={`${base}/en/articles/`}>Read reviews →</a></p>
  </div>

  <!-- Sticky sidebar -->
  <div id="sticky-sidebar" class="sticky-sidebar">
    <div class="sticky-search-wrap">
      <svg viewBox="0 0 20 20" fill="none" width="13" height="13">
        <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.8"/>
        <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <input id="sticky-search-input" type="text" class="sticky-search-input" placeholder="Search..." autocomplete="off" />
    </div>
    <nav class="sticky-cat-nav">
      <button class="sticky-cat-btn active" data-cat="all">All</button>
      {sections.map(sec => (
        <button class="sticky-cat-btn" data-cat={sec.slug}>{sec.category}</button>
      ))}
    </nav>
  </div>

  <div class="tools-top-bar">
    <div class="tools-search-wrap">
      <svg class="tools-search-icon" viewBox="0 0 20 20" fill="none">
        <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.8"/>
        <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <input id="tools-search-input" type="text" class="tools-search-input" placeholder="Search tools..." autocomplete="off" />
      <span id="tools-search-count" class="tools-search-count" style="display:none"></span>
    </div>
    <div class="tools-cat-filter" id="tools-cat-nav">
      <button class="cat-btn active" data-cat="all">All</button>
      {sections.map(sec => (
        <button class="cat-btn" data-cat={sec.slug}>{sec.category}</button>
      ))}
    </div>
    <div class="tools-price-filter" id="tools-price-nav">
      <button class="price-btn active" data-price="all">All</button>
      <button class="price-btn" data-price="Free">Free</button>
      <button class="price-btn" data-price="Paid">Paid</button>
      <button class="price-btn" data-price="Free/Paid">Freemium</button>
    </div>
  </div>

  <!-- Featured section -->
  <div class="featured-section">
    <div class="featured-header">
      <button class="sort-btn active" data-sort="popular">🔥 Popular</button>
      <button class="sort-btn" data-sort="latest">🆕 Latest</button>
    </div>
    <ul class="featured-grid">
      {(() => {
        const popularSlugs = ['chatgpt','cursor','midjourney','claude','github-copilot','notion-ai','perplexity','canva-ai'];
        return popularSlugs.map(slug => {
          const entry = sections.flatMap(s => s.items).find(e => e.slug === slug);
          if (!entry) return null;
          const data = entry.data;
          const href = `${base}/en/tools/${entry.slug}/`;
          const badgeClass = data.tag === 'Free' ? 'badge-free' : data.tag === 'Paid' ? 'badge-paid' : 'badge-freemium';
          const badgeText  = data.tag === 'Free' ? 'Free' : data.tag === 'Paid' ? 'Pro' : 'Freemium';
          return (
            <li class="tool-card featured-card" data-slug={entry.slug} data-name={data.name} data-tag={data.tag} data-sort="popular">
              <div class={`tool-badge ${badgeClass}`}>{badgeText}</div>
              <a href={href} class="tool-card-link">
                <img src={`https://www.google.com/s2/favicons?domain=${new URL(data.url).hostname}&sz=64`} alt={data.name} width="36" height="36" class="tool-favicon" loading="lazy" />
                <span class="tool-name">{data.name}</span>
                <p class="tool-desc">{(data.longDesc ?? '').slice(0,80)}{(data.longDesc ?? '').length > 80 ? '…' : ''}</p>
              </a>
              <button class="compare-btn" data-slug={entry.slug} data-name={data.name}>+ Compare</button>
            </li>
          );
        });
      })()}
      {(() => {
        const latestSlugs = ['bolt-new','v0','devin','sora','grok','gemini','copilot','perplexity'];
        return latestSlugs.map(slug => {
          const entry = sections.flatMap(s => s.items).find(e => e.slug === slug);
          if (!entry) return null;
          const data = entry.data;
          const href = `${base}/en/tools/${entry.slug}/`;
          const badgeClass = data.tag === 'Free' ? 'badge-free' : data.tag === 'Paid' ? 'badge-paid' : 'badge-freemium';
          const badgeText  = data.tag === 'Free' ? 'Free' : data.tag === 'Paid' ? 'Pro' : 'Freemium';
          return (
            <li class="tool-card featured-card" data-slug={entry.slug} data-name={data.name} data-tag={data.tag} data-sort="latest" style="display:none">
              <div class={`tool-badge ${badgeClass}`}>{badgeText}</div>
              <a href={href} class="tool-card-link">
                <img src={`https://www.google.com/s2/favicons?domain=${new URL(data.url).hostname}&sz=64`} alt={data.name} width="36" height="36" class="tool-favicon" loading="lazy" />
                <span class="tool-name">{data.name}</span>
                <p class="tool-desc">{(data.longDesc ?? '').slice(0,80)}{(data.longDesc ?? '').length > 80 ? '…' : ''}</p>
              </a>
              <button class="compare-btn" data-slug={entry.slug} data-name={data.name}>+ Compare</button>
            </li>
          );
        });
      })()}
    </ul>
  </div>

  <!-- ── Main content ── -->
  <div class="tools-main">
      {sections.map(sec => {
        const catColor = CATEGORY_COLORS[sec.slug] ?? '#4FACFE';
        const r = parseInt(catColor.slice(1,3), 16);
        const g = parseInt(catColor.slice(3,5), 16);
        const b = parseInt(catColor.slice(5,7), 16);
        return (
          <section
            class="tool-section"
            id={sec.slug}
            style={`--section-color: ${catColor}; --section-color-rgb: ${r},${g},${b};`}
          >
            <h2 class="section-title" data-collapse-toggle>
              <span class="section-title-bar"></span>
              {sec.category}
              <svg class="section-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </h2>
            <ul class="tool-grid">
              {sec.items.map(entry => {
                const data = entry.data;
                const href = `${base}/en/tools/${entry.slug}/`;
                const desc = (data.longDesc ?? '').slice(0, 80) + ((data.longDesc ?? '').length > 80 ? '…' : '');
                const badgeClass = data.tag === 'Free' ? 'badge-free' : data.tag === 'Paid' ? 'badge-paid' : 'badge-freemium';
                const badgeText = data.tag === 'Free' ? 'Free' : data.tag === 'Paid' ? 'Pro' : 'Freemium';
                return (
                  <li class="tool-card" data-slug={entry.slug} data-name={data.name} data-tag={data.tag}>
                    <div class={`tool-badge ${badgeClass}`}>{badgeText}</div>
                    <a href={href} class="tool-card-link">
                      <img
                        src={`https://www.google.com/s2/favicons?domain=${new URL(data.url).hostname}&sz=64`}
                        alt={data.name}
                        width="36" height="36"
                        class="tool-favicon"
                        loading="lazy"
                      />
                      <span class="tool-name">{data.name}</span>
                      <p class="tool-desc">{desc}</p>
                    </a>
                    <button class="compare-btn" data-slug={entry.slug} data-name={data.name}>+ Compare</button>
                  </li>
                );
              })}
            </ul>
          </section>
        );
      })}
    </div>
  </div>
</BaseLayout>

<!-- Compare hint tooltip (shown once) -->
<div id="compare-hint" class="compare-hint" style="display:none">
  <button id="compare-hint-close" class="compare-hint-close">×</button>
  <div class="compare-hint-icons">
    <img src="https://www.google.com/s2/favicons?domain=cursor.sh&sz=32" width="24" height="24" style="border-radius:6px" alt="" />
    <img src="https://www.google.com/s2/favicons?domain=github.com&sz=32" width="24" height="24" style="border-radius:6px" alt="" />
    <img src="https://www.google.com/s2/favicons?domain=claude.ai&sz=32" width="24" height="24" style="border-radius:6px" alt="" />
  </div>
  <p class="compare-hint-title">Compare Tools</p>
  <p class="compare-hint-body">Click "+ Compare" on any tool card to compare up to 3 tools side by side.</p>
</div>

<!-- Compare bar (bottom) -->
<div id="compare-bar" style="display:none">
  <div class="compare-bar-left">
    <span class="compare-bar-label">Compare</span>
    <div class="compare-bar-items" id="compare-bar-items"></div>
  </div>
  <div class="compare-bar-right">
    <button id="compare-start-btn">Compare</button>
    <button id="compare-close-bar">Clear</button>
  </div>
</div>

<!-- Compare panel -->
<div id="compare-panel" style="display:none">
  <div class="compare-panel-inner">
    <div class="compare-panel-header">
      <h3 id="compare-panel-title">Comparing 0 tools</h3>
      <button id="compare-panel-close">×</button>
    </div>
    <div id="compare-panel-body"></div>
  </div>
</div>

<script define:vars={{ compareDataMap }}>
  window.__COMPARE_DATA__ = compareDataMap;
</script>

<style>
  .page-desc { color: var(--text-dim); margin-top: 0.25rem; font-size: 0.95rem; }
  .page-desc a { color: var(--accent); font-size: 0.875rem; }

  /* ── Top bar ── */
  .tools-top-bar { margin-bottom: 20px; }
  .tools-search-wrap { position: relative; display: flex; align-items: center; margin-bottom: 12px; max-width: 400px; margin-left: auto; margin-right: auto; }
  .tools-search-icon { position: absolute; left: 0.75rem; width: 15px; height: 15px; color: var(--text-dim); pointer-events: none; }
  .tools-search-input {
    width: 100%;
    padding: 0.6rem 0.8rem 0.6rem 2.3rem;
    border: 1.5px solid var(--border); border-radius: 8px;
    background: var(--bg-card); color: var(--text); font-size: 0.875rem;
    outline: none; transition: border-color 0.15s, box-shadow 0.15s;
  }
  .tools-search-input:focus { border-color: var(--accent); box-shadow: 0 0 0 2px rgba(79,172,254,0.12); }
  .tools-search-input::placeholder { color: var(--text-dim); }
  .tools-search-count { margin-left: 10px; font-size: 0.75rem; color: var(--text-dim); font-family: var(--font-mono); white-space: nowrap; }
  .tools-cat-filter { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 6px; }
  .cat-btn {
    padding: 4px 12px; border-radius: 999px; border: 1px solid var(--border);
    background: transparent; color: var(--text-dim); font-size: 0.8rem;
    cursor: pointer; transition: background 0.15s, color 0.15s, border-color 0.15s; white-space: nowrap;
  }
  .cat-btn:hover { border-color: var(--accent); color: var(--accent); }
  .cat-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 500; }

  .tools-price-filter { display: flex; flex-wrap: wrap; gap: 6px; }
  .price-btn {
    padding: 4px 12px; border-radius: 999px; border: 1px solid var(--border);
    background: transparent; color: var(--text-dim); font-size: 0.8rem;
    cursor: pointer; transition: background 0.15s, color 0.15s, border-color 0.15s; white-space: nowrap;
  }
  .price-btn:hover { border-color: var(--accent); color: var(--accent); }
  .price-btn.active { background: rgba(79,172,254,0.12); border-color: var(--accent); color: var(--accent); font-weight: 500; }

  /* ── Featured section ── */
  .featured-section {
    margin-bottom: 2rem;
    background: rgba(79,172,254,0.03);
    border: 1px solid rgba(79,172,254,0.1);
    border-radius: 14px;
    padding: 14px 16px;
  }
  .featured-header { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
  .sort-btn {
    padding: 4px 14px; border-radius: 999px; border: 1px solid var(--border);
    background: transparent; color: var(--text-dim); font-size: 0.82rem;
    cursor: pointer; transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .sort-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 500; }
  .featured-grid {
    list-style: none; display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;
  }
  @media (max-width: 900px) { .featured-grid { grid-template-columns: repeat(2, 1fr); } }

  /* ── Main content ── */
  .tools-main { min-width: 0; }

  .tool-section {
    margin-bottom: 2rem;
    background: rgba(var(--section-color-rgb, 79,172,254), 0.02);
    border: 1px solid rgba(var(--section-color-rgb, 79,172,254), 0.07);
    border-radius: 14px;
    padding: 18px 20px;
  }

  .section-title {
    display: flex; align-items: center; gap: 10px;
    font-size: 1.1rem; font-weight: 600;
    margin-bottom: 0.875rem; padding-bottom: 0.5rem;
    border-bottom: 2px solid rgba(var(--section-color-rgb, 79,172,254), 0.2);
    color: var(--text); cursor: pointer; user-select: none;
  }
  .section-title:hover { color: var(--section-color, var(--accent)); }
  .section-chevron { margin-left: auto; flex-shrink: 0; transition: transform 0.2s; color: var(--text-dim); }
  .tool-section.collapsed .section-chevron { transform: rotate(-90deg); }
  .tool-section.collapsed .tool-grid { display: none; }
  .section-title-bar {
    display: inline-block; width: 4px; height: 1.1em;
    border-radius: 2px; background: var(--section-color, var(--accent)); flex-shrink: 0;
  }

  .tool-grid {
    list-style: none; display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;
  }
  @media (max-width: 1200px) { .tool-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px)  { .tool-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px)  { .tool-grid { grid-template-columns: 1fr; } }

  .tool-card {
    position: relative; display: flex; flex-direction: column;
    background: linear-gradient(160deg, rgba(var(--section-color-rgb,79,172,254),0.05) 0%, var(--bg-card) 55%);
    border: 1px solid rgba(var(--section-color-rgb,79,172,254),0.13);
    border-top: 3px solid var(--section-color, var(--accent));
    border-radius: 10px; transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .tool-card:hover {
    background: linear-gradient(160deg, rgba(var(--section-color-rgb,79,172,254),0.1) 0%, var(--bg-card) 60%);
    border-color: var(--section-color, var(--accent));
    transform: translateY(-3px); box-shadow: 0 10px 40px rgba(var(--section-color-rgb,79,172,254),0.14);
  }
  .tool-card.comparing { border-color: var(--section-color, var(--accent)); box-shadow: 0 0 0 2px var(--section-color, var(--accent)); }

  .tool-badge {
    position: absolute; top: 8px; right: 8px;
    font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 999px;
    color: #fff; letter-spacing: 0.03em; pointer-events: none;
  }
  .badge-free     { background: linear-gradient(90deg, #43e97b, #38f9d7); }
  .badge-paid     { background: linear-gradient(90deg, #A855F7, #6366F1); }
  .badge-freemium { background: linear-gradient(90deg, #4FACFE, #00F2FE); }

  .tool-card-link {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    padding: 12px 12px 8px; flex: 1; text-decoration: none; color: inherit;
  }
  .tool-card-link:hover { text-decoration: none; }

  .tool-favicon { width: 36px; height: 36px; border-radius: 8px; margin-bottom: 7px; flex-shrink: 0; }
  .tool-name { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 4px; transition: color 0.15s; }
  .tool-card:hover .tool-name { color: var(--section-color, var(--accent)); }

  .tool-desc {
    font-size: 11.5px; color: var(--text-dim); line-height: 1.45; flex: 1; margin-bottom: 24px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  /* Compare button — bottom-right corner */
  .compare-btn {
    position: absolute; bottom: 6px; right: 8px;
    padding: 2px 8px;
    border: 1px solid rgba(var(--section-color-rgb,79,172,254),0.3);
    border-radius: 4px; background: transparent; color: var(--text-dim);
    font-size: 11px; cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s; white-space: nowrap;
  }
  .compare-btn:hover { background: rgba(var(--section-color-rgb,79,172,254),0.08); color: var(--section-color, var(--accent)); border-color: var(--section-color, var(--accent)); }
  .compare-btn.selected { background: rgba(var(--section-color-rgb,79,172,254),0.15); color: var(--section-color, var(--accent)); border-color: var(--section-color, var(--accent)); }

  .tool-card.hidden { display: none; }
  .tool-section.section-hidden { display: none; }

  /* Compare hint tooltip */
  #compare-hint {
    position: fixed; right: 20px; top: 50%; transform: translateY(-50%);
    width: 200px; background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 12px; padding: 16px; z-index: 90;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    animation: hint-in 0.3s ease;
  }
  @keyframes hint-in { from { opacity:0; transform: translateY(-50%) translateX(12px); } to { opacity:1; transform: translateY(-50%) translateX(0); } }
  .compare-hint-close {
    position: absolute; top: 8px; right: 10px; background: none; border: none;
    cursor: pointer; color: var(--text-dim); font-size: 16px; line-height: 1; padding: 0;
  }
  .compare-hint-icons { display: flex; gap: 6px; margin-bottom: 10px; }
  .compare-hint-title { font-size: 13px; font-weight: 600; color: var(--text); margin: 0 0 6px; }
  .compare-hint-body { font-size: 12px; color: var(--text-dim); line-height: 1.5; margin: 0; }

  /* Compare bar */
  #compare-bar {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: var(--bg-card); border-top: 1px solid var(--border);
    padding: 10px 24px; display: flex; align-items: center; justify-content: space-between;
    z-index: 100; box-shadow: 0 -4px 24px rgba(0,0,0,0.15);
    animation: bar-up 0.2s ease;
  }
  @keyframes bar-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
  .compare-bar-left { display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; }
  .compare-bar-label { font-size: 12px; font-weight: 600; color: var(--text-dim); white-space: nowrap; }
  .compare-bar-items { display: flex; gap: 8px; flex-wrap: wrap; }
  .compare-bar-chip {
    display: flex; align-items: center; gap: 5px; padding: 4px 8px 4px 6px;
    background: rgba(79,172,254,0.08); border: 1px solid rgba(79,172,254,0.25);
    border-radius: 999px; font-size: 12px; color: var(--text); white-space: nowrap;
  }
  .compare-bar-chip img { border-radius: 4px; flex-shrink: 0; }
  .compare-bar-chip button {
    background: none; border: none; cursor: pointer; color: var(--text-dim);
    font-size: 14px; line-height: 1; padding: 0; margin-left: 2px;
  }
  .compare-bar-chip button:hover { color: var(--text); }
  .compare-bar-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  #compare-start-btn {
    padding: 7px 22px; background: linear-gradient(90deg, #4FACFE, #00F2FE);
    border: none; border-radius: 8px; color: #fff; font-size: 13px; font-weight: 600;
    cursor: pointer; white-space: nowrap; transition: opacity 0.15s;
  }
  #compare-start-btn:hover { opacity: 0.88; }
  #compare-close-bar {
    background: none; border: none; cursor: pointer; color: var(--text-dim);
    font-size: 13px; padding: 0 4px;
  }
  #compare-close-bar:hover { color: var(--text); }

  /* Compare panel */
  #compare-panel {
    position: fixed; inset: 0; background: rgba(0,0,0,0.65);
    z-index: 200; display: flex; align-items: center; justify-content: center; padding: 24px;
  }
  .compare-panel-inner {
    background: var(--bg-card); border-radius: 16px; width: 100%; max-width: 960px;
    max-height: 85vh; overflow-y: auto; padding: 24px; position: relative;
  }
  .compare-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px; padding-bottom: 14px; border-bottom: 1px solid var(--border);
  }
  .compare-panel-header h3 { margin: 0; font-size: 1.05rem; color: var(--text); }
  #compare-panel-close {
    background: none; border: none; cursor: pointer; color: var(--text-dim);
    font-size: 22px; line-height: 1; padding: 0;
  }

  /* Compare grid layout */
  .compare-grid {
    display: grid; gap: 0;
  }
  .compare-grid[data-count="2"] { grid-template-columns: 160px 1fr 1fr; }
  .compare-grid[data-count="3"] { grid-template-columns: 160px 1fr 1fr 1fr; }

  .cg-header-cell {
    padding: 12px 14px; text-align: center; border-bottom: 2px solid var(--border);
    border-right: 1px solid var(--border);
  }
  .cg-header-cell:last-child { border-right: none; }
  .cg-header-cell img { border-radius: 8px; margin-bottom: 6px; }
  .cg-header-cell .cg-tool-name { font-size: 13px; font-weight: 600; color: var(--text); display: block; margin-bottom: 4px; }
  .cg-header-cell a.cg-visit {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; color: var(--accent); text-decoration: none;
    border: 1px solid rgba(79,172,254,0.3); border-radius: 4px; padding: 2px 8px;
  }
  .cg-header-cell a.cg-visit:hover { background: rgba(79,172,254,0.08); }

  .cg-row-label {
    padding: 10px 14px; font-size: 12px; font-weight: 600; color: var(--text-dim);
    background: rgba(79,172,254,0.03); border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border); display: flex; align-items: flex-start;
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .cg-cell {
    padding: 10px 14px; font-size: 12.5px; color: var(--text-dim); line-height: 1.55;
    border-right: 1px solid var(--border); border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .cg-cell:last-child { border-right: none; }
  .cg-cell ul { margin: 0; padding-left: 14px; }
  .cg-cell ul li { margin-bottom: 3px; }
  .cg-cell .tag-badge {
    display: inline-block; font-size: 11px; font-weight: 600; padding: 2px 8px;
    border-radius: 999px; color: #fff;
  }
  .tag-badge.free     { background: linear-gradient(90deg,#43e97b,#38f9d7); }
  .tag-badge.paid     { background: linear-gradient(90deg,#A855F7,#6366F1); }
  .tag-badge.freemium { background: linear-gradient(90deg,#4FACFE,#00F2FE); }
  .cg-pro { color: #10B981; }
  .cg-con { color: #EF4444; }

  /* Toast */
  #compare-toast {
    position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%);
    background: #1a1a2e; color: #fff; font-size: 13px; padding: 8px 18px;
    border-radius: 8px; z-index: 300; pointer-events: none;
    opacity: 0; transition: opacity 0.2s;
  }
  #compare-toast.show { opacity: 1; }

  @media (max-width: 600px) { .tools-search-input { max-width: 100%; } }

  /* ── Sticky sidebar ── */
  .sticky-sidebar {
    position: fixed; left: 52px; top: 50%;
    transform: translateY(-50%) translateX(-16px);
    width: 160px; background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 10px; z-index: 80;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    opacity: 0; pointer-events: none; transition: opacity 0.2s, transform 0.2s;
  }
  .sticky-sidebar.visible { opacity: 1; pointer-events: auto; transform: translateY(-50%) translateX(0); }
  .sticky-search-wrap {
    display: flex; align-items: center; gap: 6px; padding: 5px 8px;
    border: 1px solid var(--border); border-radius: 6px; background: var(--bg);
    margin-bottom: 8px; color: var(--text-dim);
  }
  .sticky-search-input { flex: 1; border: none; background: transparent; color: var(--text); font-size: 0.8rem; outline: none; min-width: 0; }
  .sticky-search-input::placeholder { color: var(--text-dim); }
  .sticky-cat-nav {
    display: flex; flex-direction: column; gap: 2px;
    max-height: calc(100vh - 200px); overflow-y: auto; scrollbar-width: none;
  }
  .sticky-cat-nav::-webkit-scrollbar { display: none; }
  .sticky-cat-btn {
    text-align: left; padding: 5px 8px; border-radius: 5px; border: none;
    background: transparent; color: var(--text-dim); font-size: 0.78rem;
    cursor: pointer; transition: background 0.12s, color 0.12s;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .sticky-cat-btn:hover { background: rgba(79,172,254,0.08); color: var(--accent); }
  .sticky-cat-btn.active { background: rgba(79,172,254,0.12); color: var(--accent); font-weight: 500; }

  @media (max-width: 768px) { .sticky-sidebar { display: none; } }
</style>

<script>
  const input = document.getElementById('tools-search-input') as HTMLInputElement;
  const countEl = document.getElementById('tools-search-count')!;
  const sections = Array.from(document.querySelectorAll<HTMLElement>('.tool-section'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.tool-card:not(.featured-card)'));

  const cardTexts = cards.map(card => {
    const name = card.querySelector('.tool-name')?.textContent ?? '';
    const desc = card.querySelector('.tool-desc')?.textContent ?? '';
    return (name + ' ' + desc).toLowerCase();
  });

  let activeCategory = 'all';
  let activePrice = 'all';

  function applyFilters() {
    const q = input.value.trim().toLowerCase();
    let matched = 0;
    cards.forEach((card, i) => {
      const catMatch = activeCategory === 'all' || card.closest('.tool-section')?.id === activeCategory;
      const priceMatch = activePrice === 'all' || (card as HTMLElement).dataset.tag === activePrice;
      const textMatch = !q || cardTexts[i].includes(q);
      if (catMatch && priceMatch && textMatch) { card.classList.remove('hidden'); matched++; }
      else card.classList.add('hidden');
    });
    sections.forEach(sec => {
      sec.classList.toggle('section-hidden', sec.querySelectorAll('.tool-card:not(.hidden)').length === 0);
    });
    if (q) { countEl.textContent = `${matched} result${matched !== 1 ? 's' : ''}`; countEl.style.display = ''; }
    else countEl.style.display = 'none';
  }

  input.addEventListener('input', applyFilters);
  input.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') { input.value = ''; applyFilters(); }
  });

  // Category filter
  document.querySelectorAll<HTMLButtonElement>('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.cat ?? 'all';
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.toggle('active', b === btn));
      applyFilters();
    });
  });

  // Price filter
  document.querySelectorAll<HTMLButtonElement>('.price-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activePrice = btn.dataset.price ?? 'all';
      document.querySelectorAll('.price-btn').forEach(b => b.classList.toggle('active', b === btn));
      applyFilters();
    });
  });

  // Sort (popular/latest)
  document.querySelectorAll<HTMLButtonElement>('.sort-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const sort = btn.dataset.sort!;
      document.querySelectorAll('.sort-btn').forEach(b => b.classList.toggle('active', b === btn));
      document.querySelectorAll<HTMLElement>('.featured-card').forEach(card => {
        card.style.display = card.dataset.sort === sort ? '' : 'none';
      });
    });
  });

  // Sticky sidebar visibility
  const stickySidebar = document.getElementById('sticky-sidebar')!;
  const topBar = document.querySelector<HTMLElement>('.tools-top-bar')!;
  const stickySearchInput = document.getElementById('sticky-search-input') as HTMLInputElement;

  const topBarObserver = new IntersectionObserver(([entry]) => {
    stickySidebar.classList.toggle('visible', !entry.isIntersecting);
  }, { threshold: 0 });
  topBarObserver.observe(topBar);

  // Sticky search syncs with main search
  stickySearchInput.addEventListener('input', () => {
    input.value = stickySearchInput.value;
    input.dispatchEvent(new Event('input'));
  });
  input.addEventListener('input', () => {
    if (stickySearchInput.value !== input.value) stickySearchInput.value = input.value;
  });

  // Sticky cat buttons sync with main cat buttons
  document.querySelectorAll<HTMLButtonElement>('.sticky-cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.cat ?? 'all';
      document.querySelectorAll('.cat-btn').forEach(b =>
        b.classList.toggle('active', (b as HTMLElement).dataset.cat === activeCategory)
      );
      document.querySelectorAll('.sticky-cat-btn').forEach(b =>
        b.classList.toggle('active', b === btn)
      );
      applyFilters();
    });
  });

  // Keep sticky buttons in sync when main buttons are clicked
  document.querySelectorAll<HTMLButtonElement>('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.sticky-cat-btn').forEach(b =>
        b.classList.toggle('active', (b as HTMLElement).dataset.cat === activeCategory)
      );
    });
  });

  // Section collapse
  document.querySelectorAll<HTMLElement>('[data-collapse-toggle]').forEach(title => {
    title.addEventListener('click', () => {
      title.closest('.tool-section')?.classList.toggle('collapsed');
    });
  });

  // Compare
  type CompareItem = { slug: string; name: string; desc: string; tag: string; favicon: string };
  let compareList: CompareItem[] = [];

  const bar = document.getElementById('compare-bar')!;
  const barItems = document.getElementById('compare-bar-items')!;
  const startBtn = document.getElementById('compare-start-btn')!;
  const closeBar = document.getElementById('compare-close-bar')!;
  const panel = document.getElementById('compare-panel')!;
  const panelBody = document.getElementById('compare-panel-body')!;
  const panelClose = document.getElementById('compare-panel-close')!;

  function renderBar() {
    bar.style.display = compareList.length > 0 ? 'flex' : 'none';
    barItems.innerHTML = compareList.map(item => `
      <span class="compare-bar-chip">${item.name}<button data-slug="${item.slug}">×</button></span>
    `).join('');
    barItems.querySelectorAll<HTMLButtonElement>('button[data-slug]').forEach(btn => {
      btn.addEventListener('click', () => removeCompare(btn.dataset.slug!));
    });
  }

  function removeCompare(slug: string) {
    compareList = compareList.filter(i => i.slug !== slug);
    document.querySelectorAll<HTMLElement>(`.tool-card[data-slug="${slug}"]`).forEach(card => {
      card.classList.remove('comparing');
      const btn = card.querySelector<HTMLButtonElement>('.compare-btn');
      if (btn) { btn.textContent = '+ Compare'; btn.classList.remove('selected'); }
    });
    renderBar();
  }

  document.querySelectorAll<HTMLButtonElement>('.compare-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest<HTMLElement>('.tool-card')!;
      const slug = btn.dataset.slug!;
      const name = btn.dataset.name!;
      if (compareList.findIndex(i => i.slug === slug) >= 0) { removeCompare(slug); return; }
      if (compareList.length >= 3) { alert('Max 3 tools to compare'); return; }
      const desc = card.querySelector('.tool-desc')?.textContent ?? '';
      const tag = card.querySelector('.tool-badge')?.textContent ?? '';
      const favicon = (card.querySelector('.tool-favicon') as HTMLImageElement)?.src ?? '';
      compareList.push({ slug, name, desc, tag, favicon });
      document.querySelectorAll<HTMLElement>(`.tool-card[data-slug="${slug}"]`).forEach(c => c.classList.add('comparing'));
      btn.textContent = '✓ Selected';
      btn.classList.add('selected');
      renderBar();
    });
  });

  closeBar.addEventListener('click', () => { [...compareList.map(i => i.slug)].forEach(removeCompare); });

  startBtn.addEventListener('click', () => {
    const rows = [
      ['Name', ...compareList.map(i => `<strong>${i.name}</strong>`)],
      ['Pricing', ...compareList.map(i => i.tag)],
      ['Description', ...compareList.map(i => i.desc)],
    ];
    panelBody.innerHTML = `<table class="compare-table">
      <thead><tr><th>Attribute</th>${compareList.map(i => `<th><img src="${i.favicon}" width="20" height="20" style="border-radius:4px;vertical-align:middle;margin-right:6px">${i.name}</th>`).join('')}</tr></thead>
      <tbody>${rows.map(row => `<tr>${row.map((cell, idx) => idx === 0 ? `<th>${cell}</th>` : `<td>${cell}</td>`).join('')}</tr>`).join('')}</tbody>
    </table>`;
    panel.style.display = 'flex';
  });

  panelClose.addEventListener('click', () => { panel.style.display = 'none'; });
  panel.addEventListener('click', (e) => { if (e.target === panel) panel.style.display = 'none'; });
</script>
