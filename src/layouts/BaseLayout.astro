---
import '../styles/global.css';
import { TOOLS } from '../data/tools';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en';
}
const { title, description = 'AI 工具评测、资讯与教程', lang = 'zh' } = Astro.props;
const htmlLang = lang === 'en' ? 'en' : 'zh-CN';
const ogLocale = lang === 'en' ? 'en_US' : 'zh_CN';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const articlesHref = `${base}/${lang}/`;

const footerTools = TOOLS.flatMap(g => g.items.slice(0, 5)).map(t => ({
  name: t.name,
  href: `${base}/${lang}/tools/${t.slug}/`,
}));

const FRIENDLY_LINKS = [
  { name: '量子位',   href: 'https://www.qbitai.com' },
  { name: '少数派',   href: 'https://sspai.com' },
  { name: 'AI工具集', href: 'https://ai-bot.cn' },
  { name: '36氪',    href: 'https://36kr.com' },
];

const siteDesc = lang === 'en'
  ? 'Explore every dimension of AI — tool reviews, tutorials, industry insights and daily news, all in one place.'
  : '探索 AI 的每一个维度 —— 工具评测、深度教程、行业洞察与每日资讯，一站直达。';
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="azDQKFOaF1WTTS9FXHmNz7lDeRDGITYuJfUqcTYDqEs" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@700;800;900&display=swap" rel="stylesheet" />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content={ogLocale} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>" />
  </head>
  <body>
    <header>
      <div class="container inner">
        <a href={`${base}/`} class="logo">
          <span class="logo-ai">AI</span><span class="logo-dot">·</span><span class="logo-blog">Verse</span>
        </a>
        <nav>
          <div class="nav-links">
            <a href={articlesHref}>{lang === 'en' ? 'Home' : '首页'}</a>
            <a href={`${base}/${lang}/articles/`} class="nav-primary">{lang === 'en' ? 'Articles' : '文章'}</a>
            <a href={`${base}/${lang}/tools/`} class="nav-primary">{lang === 'en' ? 'Tools' : '工具'}</a>
            <a href={`${base}/${lang}/news/`} class="nav-primary">{lang === 'en' ? 'News' : '资讯'}</a>
            <a href={`${base}/${lang}/prompts/`} class="nav-primary">{lang === 'en' ? 'Prompts' : '提示词'}</a>
            <a href={`${base}/${lang}/about/`}>{lang === 'en' ? 'About' : '关于'}</a>
          </div>
          <div class="nav-actions">
            <button id="theme-btn" aria-label="Toggle theme">
              <svg id="theme-icon-dark" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              <svg id="theme-icon-light" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            </button>
            <a id="lang-toggle" href="#" aria-label="Switch language">{lang === 'en' ? '中' : 'EN'}</a>
          </div>
        </nav>
      </div>
    </header>

    <!-- ── 左侧导航侧边栏 ── -->
    <aside class="sidebar" id="sidebar">
      <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
        <svg class="chevron-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
      <nav class="sidebar-nav">
        <a href={`${base}/${lang}/`} class="sidebar-item">
          <span class="sidebar-icon">
            <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M224,115.55V208a16,16,0,0,1-16,16H168a16,16,0,0,1-16-16V168a8,8,0,0,0-8-8H112a8,8,0,0,0-8,8v40a16,16,0,0,1-16,16H48a16,16,0,0,1-16-16V115.55a16,16,0,0,1,5.17-11.78l80-75.48a16,16,0,0,1,21.66,0l80,75.48A16,16,0,0,1,224,115.55Z"/></svg>
          </span>
          <span class="sidebar-label">{lang === 'en' ? 'Home' : '首页'}</span>
        </a>
        <div class="sidebar-tools-wrap">
          <a href={`${base}/${lang}/articles/`} class="sidebar-item sidebar-item--tools">
            <span class="sidebar-icon">
              <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M213.66,82.34l-56-56A8,8,0,0,0,152,24H56A16,16,0,0,0,40,40V216a16,16,0,0,0,16,16H200a16,16,0,0,0,16-16V88A8,8,0,0,0,213.66,82.34ZM160,51.31,188.69,80H160ZM200,216H56V40h88V88a8,8,0,0,0,8,8h48V216Zm-32-80a8,8,0,0,1-8,8H96a8,8,0,0,1,0-16h64A8,8,0,0,1,168,136Zm0,32a8,8,0,0,1-8,8H96a8,8,0,0,1,0-16h64A8,8,0,0,1,168,168Z"/></svg>
            </span>
            <span class="sidebar-label">{lang === 'en' ? 'Articles' : '文章'}</span>
          </a>
          <button class="tools-expand-btn sidebar-label" id="articles-expand-btn" aria-label="Toggle articles menu">
            <svg class="tools-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
        </div>
        <div class="sidebar-submenu" id="articles-submenu">
          <a href={`${base}/${lang}/articles/?cat=tutorial`} class="sidebar-subitem">{lang === 'en' ? 'Deep Tutorials' : '深度教程'}</a>
          <a href={`${base}/${lang}/articles/?cat=review`} class="sidebar-subitem">{lang === 'en' ? 'Reviews' : '对比评测'}</a>
          <a href={`${base}/${lang}/articles/?cat=industry-insights`} class="sidebar-subitem">{lang === 'en' ? 'Industry Insights' : '行业洞察'}</a>
          <a href={`${base}/${lang}/articles/?cat=trending`} class="sidebar-subitem">{lang === 'en' ? 'Trending' : '热点解析'}</a>
        </div>
        <a href={`${base}/${lang}/tools/`} class="sidebar-item">
          <span class="sidebar-icon">
            <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M221.86,114.72A8,8,0,0,0,216,112H168V88a8,8,0,0,0-4.42-7.14l-112-56A8,8,0,0,0,40,32V224a8,8,0,0,0,16,0V168h56v24a8,8,0,0,0,4.42,7.14l80,40A8,8,0,0,0,208,232V120A8,8,0,0,0,221.86,114.72ZM56,152V52.94l96,48V152Z"/></svg>
          </span>
          <span class="sidebar-label">{lang === 'en' ? 'Tools' : '工具'}</span>
        </a>
        <a href={`${base}/${lang}/news/`} class="sidebar-item">
          <span class="sidebar-icon">
            <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40Zm0,160H40V56H216V200ZM184,96a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,96Zm0,32a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,128Zm0,32a8,8,0,0,1-8,8H80a8,8,0,0,1,0-16h96A8,8,0,0,1,184,160Z"/></svg>
          </span>
          <span class="sidebar-label">{lang === 'en' ? 'Daily News' : '每日资讯'}</span>
        </a>
        <a href={`${base}/${lang}/prompts/`} class="sidebar-item">
          <span class="sidebar-icon">
            <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M208,144a15.78,15.78,0,0,1-10.42,14.94L146,178.74l-19.29,51.62a16,16,0,0,1-29.88.35L39.06,64.29A16,16,0,0,1,64.29,39.06l166.42,57.77A16,16,0,0,1,224,112a15.78,15.78,0,0,1-14.94,10.42L160,104.94V144ZM224,56a8,8,0,0,0-8-8H208V40a8,8,0,0,0-16,0v8H184a8,8,0,0,0,0,16h8v8a8,8,0,0,0,16,0V64h8A8,8,0,0,0,224,56ZM144,24a8,8,0,0,0,8-8V8a8,8,0,0,0-16,0v8A8,8,0,0,0,144,24Zm72,144a8,8,0,0,0-8,8v8h-8a8,8,0,0,0,0,16h8v8a8,8,0,0,0,16,0v-8h8a8,8,0,0,0,0-16h-8v-8A8,8,0,0,0,216,168Z"/></svg>
          </span>
          <span class="sidebar-label">{lang === 'en' ? 'Prompts' : '提示词'}</span>
        </a>
        <a href={`${base}/${lang}/about/`} class="sidebar-item">
          <span class="sidebar-icon">
            <svg width="18" height="18" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216Zm16-40a8,8,0,0,1-8,8,16,16,0,0,1-16-16V128a8,8,0,0,1,0-16,16,16,0,0,1,16,16v40A8,8,0,0,1,144,176ZM112,84a16,16,0,1,1,16,16A16,16,0,0,1,112,84Z"/></svg>
          </span>
          <span class="sidebar-label">{lang === 'en' ? 'About' : '关于'}</span>
        </a>
      </nav>
    </aside>

    <main style="padding-top: 80px; margin-left: 48px; padding-left: 32px; padding-right: 32px; padding-bottom: 80px;"><div style="max-width: 1080px; margin: 0 auto;">
      <slot />
    </div></main>

    <footer>
      <div class="container footer-body">
        <!-- 左：站点简介 -->
        <div class="footer-about">
          <div class="footer-logo">
            <span class="logo-ai">AI</span><span class="logo-dot">·</span>Verse
          </div>
          <p class="footer-desc">{siteDesc}</p>
          <div class="footer-copy">© 2026 AI Verse</div>
        </div>
        <!-- 右：工具导航 + 友情链接 -->
        <div class="footer-nav">
          <div class="footer-nav-block">
            <div class="footer-nav-label">{lang === 'en' ? 'AI Tools' : 'AI 工具导航'}</div>
            <div class="footer-link-cloud">
              {footerTools.map(t => (
                <a href={t.href} class="footer-cloud-link">{t.name}</a>
              ))}
            </div>
          </div>
          <div class="footer-nav-block">
            <div class="footer-nav-label">{lang === 'en' ? 'Friendly Links' : '友情链接'}</div>
            <div class="footer-link-cloud">
              {FRIENDLY_LINKS.map(l => (
                <a href={l.href} target="_blank" rel="noopener noreferrer" class="footer-cloud-link">{l.name}</a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </footer>

    <style is:global>
      /* ── Sidebar ── */
      .sidebar {
        position: fixed;
        left: 0;
        top: var(--header-h, 56px);
        bottom: 0;
        width: 48px;
        background: var(--bg-card);
        border-right: 1px solid var(--border);
        z-index: 90;
        transition: width 0.22s cubic-bezier(0.4,0,0.2,1);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .sidebar[data-open] {
        width: 200px;
        box-shadow: 4px 0 24px rgba(0,0,0,0.18);
      }
      .sidebar-toggle {
        width: 48px;
        height: 48px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        border-bottom: 1px solid var(--border);
        color: var(--text-dim);
        cursor: pointer;
        transition: color 0.15s, background 0.15s;
      }
      .sidebar-toggle:hover { color: var(--accent); background: rgba(79,172,254,0.06); }
      .sidebar-nav {
        display: flex;
        flex-direction: column;
        padding: 8px 0;
        flex: 1;
      }
      .sidebar-item {
        display: flex;
        align-items: center;
        height: 44px;
        padding: 0;
        width: 100%;
        color: var(--text-dim);
        text-decoration: none;
        white-space: nowrap;
        transition: color 0.15s, background 0.15s;
        border-left: 2px solid transparent;
        flex-shrink: 0;
      }
      .sidebar-item:hover {
        color: var(--accent);
        background: rgba(79,172,254,0.08);
        border-left-color: var(--accent);
        text-decoration: none;
      }
      .sidebar-icon {
        width: 48px;
        height: 44px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .sidebar-label {
        font-size: 0.875rem;
        font-weight: 500;
        display: none;
        flex: 1;
        min-width: 0;
      }
      .sidebar[data-open] .sidebar-label {
        display: flex;
        align-items: center;
      }

      @media (max-width: 640px) {
        .sidebar { display: none; }
      }

      /* Tools wrap */
      .sidebar-tools-wrap {
        display: flex;
        align-items: center;
        width: 100%;
      }
      .sidebar-item--tools {
        flex: 1;
      }
      .tools-expand-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--text-dim);
        padding: 0 10px 0 4px;
        height: 44px;
        display: flex;
        align-items: center;
        flex-shrink: 0;
        transition: color 0.15s;
      }
      .tools-expand-btn:hover { color: var(--accent); }
      .tools-chevron { transition: transform 0.2s; }
      .tools-expand-btn[data-open] .tools-chevron { transform: rotate(180deg); }

      /* Submenu */
      .sidebar-submenu {
        display: none;
        flex-direction: column;
      }
      .sidebar-submenu[data-open] { display: flex; }
      .sidebar-subitem {
        display: flex;
        align-items: center;
        height: 36px;
        padding: 0 12px 0 48px;
        color: var(--text-dim);
        text-decoration: none;
        font-size: 0.8rem;
        white-space: nowrap;
        transition: color 0.15s, background 0.15s;
        border-left: 2px solid transparent;
        width: 100%;
      }
      .sidebar-subitem:hover {
        color: var(--accent);
        background: rgba(79,172,254,0.06);
        border-left-color: var(--accent);
        text-decoration: none;
      }

      /* Chevron rotation */
      .chevron-icon {
        transition: transform 0.22s cubic-bezier(0.4,0,0.2,1);
      }
      .sidebar[data-open] .chevron-icon {
        transform: rotate(180deg);
      }

      .logo-ai {
        background: linear-gradient(135deg, #4FACFE 0%, #A855F7 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .logo-dot {
        color: #A855F7;
        font-weight: 800;
      }
      .logo-blog {
        /* inherits default logo color */
      }
      /* Gradient bottom border on header */
      body > header {
      }
      body > header::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent 0%, rgba(79,172,254,0.5) 30%, rgba(168,85,247,0.5) 70%, transparent 100%);
        pointer-events: none;
      }

      /* ── 主题切换 View Transition 动画 ── */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
      }
      /* 新主题从按钮位置圆形扩散展开 */
      ::view-transition-new(root) {
        animation: vt-reveal 1.2s cubic-bezier(0.4, 0, 0.2, 1) both;
        clip-path: circle(0% at var(--vt-x, 50%) var(--vt-y, 50%));
      }
      @keyframes vt-reveal {
        from { clip-path: circle(0% at var(--vt-x, 50%) var(--vt-y, 50%)); }
        to   { clip-path: circle(160% at var(--vt-x, 50%) var(--vt-y, 50%)); }
      }
      /* 减少动画偏好：直接切换 */
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-new(root) { animation: none; }
      }
      .nav-primary {
        font-weight: 700;
      }
      footer {
        margin-left: 48px;
        padding: 40px 32px 28px;
        position: relative;
        background: var(--bg-card);
      }
      [data-theme="light"] footer {
        background: #ffffff;
        box-shadow: inset 0 1px 0 #e8eaed;
      }
      footer::before { display: none; }
      .footer-body {
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 48px;
        align-items: start;
        max-width: 1080px;
        margin: 0 auto 24px;
      }
      @media (max-width: 700px) {
        .footer-body { grid-template-columns: 1fr; gap: 24px; }
      }

      /* 左：简介 */
      .footer-logo {
        font-family: 'Outfit', sans-serif;
        font-size: 17px; font-weight: 800;
        margin-bottom: 8px;
        display: flex; align-items: center; gap: 2px;
      }
      .footer-desc {
        font-size: 12px; color: var(--text-dim);
        line-height: 1.7; margin-bottom: 12px;
        font-family: var(--font-sans);
      }
      .footer-copy {
        font-size: 11px; color: var(--text-dim); opacity: 0.5;
        font-family: var(--font-sans);
      }

      /* 右：导航块 */
      .footer-nav { display: flex; flex-direction: column; gap: 20px; }
      .footer-nav-label {
        font-size: 11px; font-weight: 700;
        letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--text-dim); margin-bottom: 8px;
        font-family: var(--font-sans);
      }
      .footer-link-cloud {
        display: flex; flex-wrap: wrap;
        row-gap: 6px; column-gap: 0;
        line-height: 1.6;
      }
      .footer-cloud-link {
        font-size: 13px; color: var(--text-dim);
        font-family: var(--font-sans);
        text-decoration: none;
        transition: color 0.15s;
        white-space: nowrap;
      }
      .footer-cloud-link:hover { color: var(--accent); text-decoration: none; }
      .footer-cloud-link::after {
        content: '·';
        margin: 0 6px;
        opacity: 0.35;
        color: var(--text-dim);
      }
      .footer-cloud-link:last-child::after { display: none; }
    </style>

    <script>
      // Sidebar toggle
      const sidebar = document.getElementById('sidebar') as HTMLElement;
      const sidebarToggle = document.getElementById('sidebar-toggle') as HTMLButtonElement;
      const articlesExpandBtn = document.getElementById('articles-expand-btn') as HTMLButtonElement;
      const articlesSubmenu = document.getElementById('articles-submenu') as HTMLDivElement;

      articlesExpandBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        if (articlesExpandBtn.hasAttribute('data-open')) {
          articlesExpandBtn.removeAttribute('data-open');
          articlesSubmenu.removeAttribute('data-open');
        } else {
          articlesExpandBtn.setAttribute('data-open', '');
          articlesSubmenu.setAttribute('data-open', '');
        }
      });

      sidebarToggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        if (sidebar.hasAttribute('data-open')) {
          sidebar.removeAttribute('data-open');
          articlesExpandBtn?.removeAttribute('data-open');
          articlesSubmenu?.removeAttribute('data-open');
        } else {
          sidebar.setAttribute('data-open', '');
        }
      });

      document.addEventListener('click', (e) => {
        if (sidebar?.hasAttribute('data-open') && !sidebar.contains(e.target as Node)) {
          sidebar.removeAttribute('data-open');
          articlesExpandBtn?.removeAttribute('data-open');
          articlesSubmenu?.removeAttribute('data-open');
        }
      });

      // Theme toggle
      const themeBtn = document.getElementById('theme-btn') as HTMLButtonElement;
      const iconDark = document.getElementById('theme-icon-dark') as SVGElement;
      const iconLight = document.getElementById('theme-icon-light') as SVGElement;

      function applyTheme(theme: string) {
        document.documentElement.setAttribute('data-theme', theme);
        if (theme === 'light') {
          iconDark.style.display = 'none';
          iconLight.style.display = '';
        } else {
          iconDark.style.display = '';
          iconLight.style.display = 'none';
        }
      }

      const saved = localStorage.getItem('theme') || 'dark';
      applyTheme(saved);

      themeBtn.addEventListener('click', (e) => {
        const next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';

        // 记录点击位置，作为动画圆心
        const rect = themeBtn.getBoundingClientRect();
        const x = Math.round(rect.left + rect.width / 2);
        const y = Math.round(rect.top + rect.height / 2);
        document.documentElement.style.setProperty('--vt-x', `${x}px`);
        document.documentElement.style.setProperty('--vt-y', `${y}px`);

        // 不支持 View Transitions 时直接切换
        if (!document.startViewTransition) {
          localStorage.setItem('theme', next);
          applyTheme(next);
          return;
        }

        const transition = document.startViewTransition(() => {
          localStorage.setItem('theme', next);
          applyTheme(next);
        });
      });

      const toggle = document.getElementById('lang-toggle') as HTMLAnchorElement;
      const path = window.location.pathname;
      if (path.includes('/zh/')) {
        toggle.href = path.replace('/zh/', '/en/');
      } else if (path.includes('/en/')) {
        toggle.href = path.replace('/en/', '/zh/');
      }

    </script>
  </body>
</html>
